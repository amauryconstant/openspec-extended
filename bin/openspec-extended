#!/usr/bin/env bash
# OpenSpec-extended - Installer for OpenSpec resources
# Usage: openspec-extended <install|update> <tool> [--with-core]

set -euo pipefail

readonly SCRIPT_NAME="openspec-extended"
readonly SCRIPT_VERSION="0.13.0"

SCRIPT_SOURCE="${BASH_SOURCE[0]:-$0}"
while [[ -L "$SCRIPT_SOURCE" ]]; do
    SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_SOURCE")" && pwd)"
    SCRIPT_SOURCE="$(readlink "$SCRIPT_SOURCE")"
    [[ "$SCRIPT_SOURCE" != /* ]] && SCRIPT_SOURCE="$SCRIPT_DIR/$SCRIPT_SOURCE"
done
SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_SOURCE")" && pwd)"
readonly SCRIPT_DIR

RESOURCES_DIR=""

resolve_install_dirs() {
    local install_base=""
    
    local xdg_data_home="${XDG_DATA_HOME:-$HOME/.local/share}"
    if [[ -d "$xdg_data_home/openspec-extended/resources" ]]; then
        install_base="$xdg_data_home/openspec-extended"
    elif [[ -d "$HOME/.local/share/openspec-extended/resources" ]]; then
        install_base="$HOME/.local/share/openspec-extended"
    fi
    
    if [[ -d "$SCRIPT_DIR/../resources" ]]; then
        RESOURCES_DIR="$(cd "$SCRIPT_DIR/../resources" && pwd)"
        return 0
    fi
    
    if [[ -n "$install_base" ]]; then
        RESOURCES_DIR="$install_base/resources"
        return 0
    fi
    
    log_error "Cannot find resources directory"
    log_error "  Checked: $SCRIPT_DIR/../resources"
    log_error "  Checked: $xdg_data_home/openspec-extended/resources"
    exit 1
}

readonly COLOR_GREEN='\033[0;32m'
readonly COLOR_RED='\033[0;31m'
readonly COLOR_YELLOW='\033[0;33m'
readonly COLOR_RESET='\033[0m'

get_tool_dir() {
    case "$1" in
        opencode) echo ".opencode" ;;
        claude)   echo ".claude" ;;
        *)        return 1 ;;
    esac
}

log_success() {
    echo -e "${COLOR_GREEN}✓${COLOR_RESET} $*"
}

log_info() {
    echo -e "→ $*"
}

log_error() {
    echo -e "${COLOR_RED}✗${COLOR_RESET} $*" >&2
}

log_warn() {
    echo -e "${COLOR_YELLOW}!${COLOR_RESET} $*"
}

get_git_tag() {
    git -C "$SCRIPT_DIR" describe --tags --abbrev=0 2>/dev/null | sed 's/^v//' && return
    echo "$SCRIPT_VERSION"
}

show_version() {
    echo "$SCRIPT_NAME $SCRIPT_VERSION"
}

show_help() {
    cat << EOF
$SCRIPT_NAME - Installer for OpenSpec resources

Usage:
  $SCRIPT_NAME <command> <tool> [options]
  $SCRIPT_NAME run <change-id> [options]
  $SCRIPT_NAME --version
  $SCRIPT_NAME --help

Commands:
  install <tool>  Add missing resources (skip existing)
  update <tool>   Force update all resources (overwrite existing)
  run             Run autonomous implementation workflow

Available tools:
  opencode        Install to .opencode/ directory
  claude          Install to .claude/ directory

Options:
  --with-core     Also deploy core OpenSpec skills from openspec-core/
  --version       Show version
  --help          Show this help message

Run '$SCRIPT_NAME run --help' for workflow options.

Examples:
  $SCRIPT_NAME install opencode
  $SCRIPT_NAME install opencode --with-core
  $SCRIPT_NAME update claude
  $SCRIPT_NAME run my-change -v
EOF
}

copy_skills() {
    local source_dir="$1"
    local target_dir="$2"
    local force="$3"
    
    local processed_count=0
    local skipped_count=0
    
    while IFS= read -r -d '' skill_dir; do
        local skill_name
        skill_name=$(basename "$skill_dir")
        local target_skill_dir="$target_dir/$skill_name"
        
        if [[ "$force" == "true" ]]; then
            cp -r "$skill_dir" "$target_dir/"
            processed_count=$((processed_count + 1))
        else
            if [[ -d "$target_skill_dir" ]]; then
                skipped_count=$((skipped_count + 1))
            else
                cp -r "$skill_dir" "$target_dir/"
                processed_count=$((processed_count + 1))
            fi
        fi
    done < <(find "$source_dir" -mindepth 1 -maxdepth 1 -type d -print0 2>/dev/null)
    
    echo "$processed_count:$skipped_count"
}

show_usage() {
    log_error "Usage: $SCRIPT_NAME <command> <tool> [--with-core]"
    log_error "       $SCRIPT_NAME run <change-id> [options]"
    echo
    echo "Commands:"
    echo "  install <tool>  Add missing resources (skip existing)"
    echo "  update <tool>   Force update all resources (overwrite existing)"
    echo "  run             Run autonomous implementation workflow"
    echo
    echo "Available tools: opencode, claude"
    echo
    echo "Run '$SCRIPT_NAME --help' for more information."
}

run_auto() {
    local script_path="$(pwd)/.opencode/scripts/osx-orchestrate"
    
    if [[ ! -f "$script_path" ]]; then
        log_error "osx-orchestrate not found"
        log_error "Run: $SCRIPT_NAME install opencode"
        exit 1
    fi
    
    exec "$script_path" "$@"
}

update_gitignore() {
    local force="$1"
    local gitignore="$(pwd)/.gitignore"
    local marker_start="# BEGIN OpenSpec autonomous workflow state"
    local marker_end="# END OpenSpec autonomous workflow state"
    
    if [[ ! -f "$gitignore" ]]; then
        touch "$gitignore"
    fi
    
    if [[ "$force" == "true" ]]; then
        local content
        content=$(sed "/^$marker_start$/,/^$marker_end$/d" "$gitignore" 2>/dev/null || cat "$gitignore")
        echo "$content" > "$gitignore"
    elif grep -qF "$marker_start" "$gitignore" 2>/dev/null; then
        return 0
    fi
    
    {
        echo ""
        echo "$marker_start"
        echo ".openspec-baseline.json"
        echo "openspec/changes/*/state.json"
        echo "openspec/changes/*/complete.json"
        echo "openspec/changes/*/iterations.json"
        echo "openspec/changes/*/decision-log.json"
        echo "openspec/changes/*/verification-report.md"
        echo "openspec/changes/*/reflections.md"
        echo "openspec/changes/*/test-compliance-report.md"
        echo "openspec/changes/*/suggestions.md"
        echo ".osx-orchestrate-*.log"
        echo "$marker_end"
    } >> "$gitignore"
    
    log_success "Added OpenSpec state files to .gitignore"
}

deploy_core() {
    local tool="$1"
    
    if ! command -v openspec &>/dev/null; then
        log_error "openspec CLI not found. Install it first:"
        echo "  npm install -g @fission-ai/openspec"
        return 1
    fi
    
    log_info "Delegating to openspec CLI for core resources..."
    
    local output
    if output=$(openspec init --tools "$tool" --force 2>&1); then
        log_success "Core resources installed via openspec"
        rename_core_resources "$tool"
        remove_conflicting_core_resources "$tool"
    else
        log_error "openspec init failed"
        echo "$output" >&2
        return 1
    fi
}

rename_core_resources() {
    local tool="$1"
    local target_dir
    target_dir=$(get_tool_dir "$tool")
    
    log_info "Renaming core resources (opsx-* → osc-*, openspec-* → osc-*)..."
    
    local renamed_count=0
    
    if [[ -d "$target_dir/commands" ]]; then
        while IFS= read -r -d '' cmd_file; do
            local basename
            basename=$(basename "$cmd_file")
            local dirname
            dirname=$(dirname "$cmd_file")
            
            if [[ "$basename" =~ ^opsx-(.+)\.md$ ]]; then
                local new_name="osc-${BASH_REMATCH[1]}.md"
                mv "$cmd_file" "$dirname/$new_name"
                renamed_count=$((renamed_count + 1))
            fi
        done < <(find "$target_dir/commands" -type f -name "opsx-*.md" -print0 2>/dev/null)
        
        if [[ -d "$target_dir/commands/osx" ]]; then
            if [[ ! -d "$target_dir/commands/osc" ]]; then
                mv "$target_dir/commands/osx" "$target_dir/commands/osc"
            else
                mv "$target_dir/commands/osx"/*.md "$target_dir/commands/osc/" 2>/dev/null || true
                rmdir "$target_dir/commands/osx" 2>/dev/null || true
            fi
            renamed_count=$((renamed_count + 1))
        fi
    fi
    
    if [[ -d "$target_dir/skills" ]]; then
        while IFS= read -r -d '' skill_dir; do
            local basename
            basename=$(basename "$skill_dir")
            local dirname
            dirname=$(dirname "$skill_dir")
            
            if [[ "$basename" =~ ^openspec-(.+)$ ]]; then
                local new_name="osc-${BASH_REMATCH[1]}"
                mv "$skill_dir" "$dirname/$new_name"
                
                if [[ -f "$dirname/$new_name/SKILL.md" ]]; then
                    sed -i "s/^name: openspec-/name: osc-/" "$dirname/$new_name/SKILL.md"
                fi
                renamed_count=$((renamed_count + 1))
            fi
        done < <(find "$target_dir/skills" -mindepth 1 -maxdepth 1 -type d -name "openspec-*" -print0 2>/dev/null)
    fi
    
    if [[ $renamed_count -gt 0 ]]; then
        log_success "Renamed $renamed_count core resource(s)"
    fi
}

remove_conflicting_core_resources() {
    local tool="$1"
    local target_dir
    target_dir=$(get_tool_dir "$tool")
    
    log_info "Removing core resources that conflict with extended resources..."
    
    local removed_count=0
    
    if [[ -d "$target_dir/commands" ]]; then
        while IFS= read -r -d '' cmd_file; do
            local basename
            basename=$(basename "$cmd_file")
            
            if [[ "$basename" =~ ^osc-(.+)\.md$ ]]; then
                local osx_name="osx-${BASH_REMATCH[1]}.md"
                
                if [[ -f "$target_dir/commands/$osx_name" ]]; then
                    rm "$cmd_file"
                    removed_count=$((removed_count + 1))
                fi
            fi
        done < <(find "$target_dir/commands" -maxdepth 1 -type f -name "osc-*.md" -print0 2>/dev/null)
    fi
    
    if [[ $removed_count -gt 0 ]]; then
        log_success "Removed $removed_count conflicting core resource(s)"
    fi
}

validate_deployment() {
    local target_dir="$1"
    local manifest="$2"
    local warnings=0
    
    if [[ ! -d "$target_dir" ]]; then
        return 0
    fi
    
    local resource_names
    resource_names=$(echo "$manifest" | jq -r '.resources | to_entries[] | .value | keys[]' 2>/dev/null | sort -u || true)
    
    for resource_name in $resource_names; do
        local found=false
        
        if [[ -d "$target_dir/skills/$resource_name" ]]; then
            found=true
        elif [[ -f "$target_dir/agents/$resource_name.md" ]]; then
            found=true
        elif [[ -f "$target_dir/commands/$resource_name.md" ]]; then
            found=true
        elif [[ -f "$target_dir/commands/osx/${resource_name#osx-}.md" ]]; then
            found=true
        elif [[ -f "$target_dir/scripts/$resource_name" ]]; then
            found=true
        elif [[ -f "$target_dir/scripts/lib/$resource_name" ]]; then
            found=true
        fi
        
        if [[ "$found" == "false" ]]; then
            log_warn "Resource '$resource_name' in manifest but not deployed"
            warnings=$((warnings + 1))
        fi
    done
    
    if [[ $warnings -gt 0 ]]; then
        echo "  Validation: $warnings warning(s)"
    fi
}

if [[ $# -eq 0 ]]; then
    show_usage
    exit 1
fi

if [[ "$1" == "--version" ]] || [[ "$1" == "-V" ]]; then
    show_version
    exit 0
fi

if [[ "$1" == "--help" ]] || [[ "$1" == "-h" ]]; then
    show_help
    exit 0
fi

if [[ "$1" == "run" ]]; then
    shift
    run_auto "$@"
fi

if [[ $# -lt 2 ]]; then
    show_usage
    exit 1
fi

resolve_install_dirs

COMMAND="$1"
TOOL="$2"
WITH_CORE=false

shift 2
while [[ $# -gt 0 ]]; do
    case "$1" in
        --with-core)
            WITH_CORE=true
            shift
            ;;
        *)
            log_error "Unknown option: $1"
            show_usage
            exit 1
            ;;
    esac
done

if [[ "$COMMAND" != "install" && "$COMMAND" != "update" ]]; then
    log_error "Unknown command: $COMMAND"
    echo
    echo "Available commands: install, update"
    echo
    show_usage
    exit 1
fi

set +e
_target_dir=$(get_tool_dir "$TOOL")
_tool_rc=$?
set -e
case $_tool_rc in
    0) TARGET_DIR="$_target_dir" ;;
    *) 
        log_error "Unknown tool: $TOOL"
        echo "  Available tools: opencode, claude"
        exit 1
        ;;
esac

GIT_VERSION=$(get_git_tag)
FULL_PATH="$(pwd)/$TARGET_DIR"
SOURCE_MANIFEST="$RESOURCES_DIR/$TOOL/manifest.json"

mkdir -p "$FULL_PATH/skills"

if [[ -d "$RESOURCES_DIR/$TOOL/skills" ]]; then
    if [[ "$COMMAND" == "update" ]]; then
        RESULT=$(copy_skills "$RESOURCES_DIR/$TOOL/skills" "$FULL_PATH/skills" "true")
        UPDATED_COUNT="${RESULT%%:*}"
        
        if [[ $UPDATED_COUNT -gt 0 ]]; then
            log_success "Updated $UPDATED_COUNT skill(s) in $TOOL (v$GIT_VERSION)"
            echo "  Target: $TARGET_DIR/skills"
        else
            echo "No skills found in resources/$TOOL/skills/"
        fi
    else
        RESULT=$(copy_skills "$RESOURCES_DIR/$TOOL/skills" "$FULL_PATH/skills" "false")
        INSTALLED_COUNT="${RESULT%%:*}"
        SKIPPED_COUNT="${RESULT##*:}"
        
        if [[ $INSTALLED_COUNT -gt 0 ]]; then
            log_success "Installed $INSTALLED_COUNT skill(s) to $TOOL (v$GIT_VERSION)"
            echo "  Target: $TARGET_DIR/skills"
        fi
        
        if [[ $SKIPPED_COUNT -gt 0 ]]; then
            echo "  Skipped $SKIPPED_COUNT existing skill(s)"
        fi
        
        if [[ $INSTALLED_COUNT -eq 0 && $SKIPPED_COUNT -eq 0 ]]; then
            echo "No skills found in resources/$TOOL/skills/"
        fi
    fi
else
    echo "resources/$TOOL/skills/ directory not found"
fi

COMMANDS_DIR="$FULL_PATH/commands"
if [[ -d "$RESOURCES_DIR/$TOOL/commands" ]]; then
    mkdir -p "$COMMANDS_DIR"
    
    if [[ "$COMMAND" == "update" ]]; then
        FLAT_COMMAND_COUNT=$(find "$RESOURCES_DIR/$TOOL/commands" -mindepth 1 -maxdepth 1 -type f -name "*.md" 2>/dev/null | wc -l)
        if [[ $FLAT_COMMAND_COUNT -gt 0 ]]; then
            cp -f "$RESOURCES_DIR/$TOOL/commands"/*.md "$COMMANDS_DIR/"
            log_success "Updated $FLAT_COMMAND_COUNT command(s) in $TOOL"
            echo "  Target: $TARGET_DIR/commands/"
        fi
        
        for subdir in "$RESOURCES_DIR/$TOOL/commands"/*/; do
            if [[ -d "$subdir" ]]; then
                subdir_name=$(basename "$subdir")
                NESTED_COMMAND_COUNT=$(find "$subdir" -mindepth 1 -maxdepth 1 -type f -name "*.md" 2>/dev/null | wc -l)
                if [[ $NESTED_COMMAND_COUNT -gt 0 ]]; then
                    mkdir -p "$COMMANDS_DIR/$subdir_name"
                    cp -f "$subdir"*.md "$COMMANDS_DIR/$subdir_name/"
                    log_success "Updated $NESTED_COMMAND_COUNT command(s) in $TOOL/$subdir_name"
                    echo "  Target: $TARGET_DIR/commands/$subdir_name/"
                fi
            fi
        done
    else
        NEW_COMMAND_COUNT=0
        while IFS= read -r -d '' cmd_file; do
            cmd_name=$(basename "$cmd_file")
            if [[ ! -f "$COMMANDS_DIR/$cmd_name" ]]; then
                cp "$cmd_file" "$COMMANDS_DIR/"
                NEW_COMMAND_COUNT=$((NEW_COMMAND_COUNT + 1))
            fi
        done < <(find "$RESOURCES_DIR/$TOOL/commands" -mindepth 1 -maxdepth 1 -type f -name "*.md" -print0 2>/dev/null)
        
        if [[ $NEW_COMMAND_COUNT -gt 0 ]]; then
            log_success "Installed $NEW_COMMAND_COUNT command(s) to $TOOL"
            echo "  Target: $TARGET_DIR/commands/"
        fi
        
        for subdir in "$RESOURCES_DIR/$TOOL/commands"/*/; do
            if [[ -d "$subdir" ]]; then
                subdir_name=$(basename "$subdir")
                mkdir -p "$COMMANDS_DIR/$subdir_name"
                
                NEW_NESTED_COUNT=0
                while IFS= read -r -d '' cmd_file; do
                    cmd_name=$(basename "$cmd_file")
                    if [[ ! -f "$COMMANDS_DIR/$subdir_name/$cmd_name" ]]; then
                        cp "$cmd_file" "$COMMANDS_DIR/$subdir_name/"
                        NEW_NESTED_COUNT=$((NEW_NESTED_COUNT + 1))
                    fi
                done < <(find "$subdir" -mindepth 1 -maxdepth 1 -type f -name "*.md" -print0 2>/dev/null)
                
                if [[ $NEW_NESTED_COUNT -gt 0 ]]; then
                    log_success "Installed $NEW_NESTED_COUNT command(s) to $TOOL/$subdir_name"
                    echo "  Target: $TARGET_DIR/commands/$subdir_name/"
                fi
            fi
        done
    fi
fi

SCRIPTS_DIR="$FULL_PATH/scripts"
if [[ -d "$RESOURCES_DIR/$TOOL/scripts" ]]; then
    mkdir -p "$SCRIPTS_DIR"
    SCRIPT_COUNT=$(find "$RESOURCES_DIR/$TOOL/scripts" -mindepth 1 -maxdepth 1 -type f 2>/dev/null | wc -l)
    
    if [[ $SCRIPT_COUNT -gt 0 ]]; then
        if [[ "$COMMAND" == "update" ]]; then
            find "$RESOURCES_DIR/$TOOL/scripts" -mindepth 1 -maxdepth 1 -type f -exec cp -f {} "$SCRIPTS_DIR/" \;
            find "$SCRIPTS_DIR" -type f -name "*.sh" -exec chmod +x {} \;
            if [[ -f "$SCRIPTS_DIR/osx-orchestrate" ]]; then
                chmod +x "$SCRIPTS_DIR/osx-orchestrate"
            fi
            log_success "Updated $SCRIPT_COUNT script(s) in $TOOL"
            echo "  Target: $TARGET_DIR/scripts/"
        else
            NEW_SCRIPT_COUNT=0
            while IFS= read -r -d '' script_file; do
                script_name=$(basename "$script_file")
                if [[ ! -f "$SCRIPTS_DIR/$script_name" ]]; then
                    cp "$script_file" "$SCRIPTS_DIR/"
                    if [[ "$script_name" == *.sh ]]; then
                        chmod +x "$SCRIPTS_DIR/$script_name"
                    fi
                    if [[ "$script_name" == "osx-orchestrate" ]]; then
                        chmod +x "$SCRIPTS_DIR/$script_name"
                    fi
                    NEW_SCRIPT_COUNT=$((NEW_SCRIPT_COUNT + 1))
                fi
            done < <(find "$RESOURCES_DIR/$TOOL/scripts" -mindepth 1 -maxdepth 1 -type f -print0)
            
            if [[ $NEW_SCRIPT_COUNT -gt 0 ]]; then
                log_success "Installed $NEW_SCRIPT_COUNT script(s) to $TOOL"
                echo "  Target: $TARGET_DIR/scripts/"
            fi
        fi
    fi
    
    if [[ -d "$RESOURCES_DIR/$TOOL/scripts/lib" ]]; then
        mkdir -p "$SCRIPTS_DIR/lib"
        
        if [[ -f "$RESOURCES_DIR/$TOOL/scripts/lib/osx" ]]; then
            if [[ "$COMMAND" == "update" ]]; then
                cp -f "$RESOURCES_DIR/$TOOL/scripts/lib/osx" "$SCRIPTS_DIR/lib/"
            else
                if [[ ! -f "$SCRIPTS_DIR/lib/osx" ]]; then
                    cp "$RESOURCES_DIR/$TOOL/scripts/lib/osx" "$SCRIPTS_DIR/lib/"
                fi
            fi
            chmod +x "$SCRIPTS_DIR/lib/osx"
            log_success "Deployed osx tool to $TOOL"
            echo "  Target: $TARGET_DIR/scripts/lib/osx"
        fi
        
        if [[ -f "$RESOURCES_DIR/$TOOL/scripts/lib/AGENTS.md" ]]; then
            if [[ "$COMMAND" == "update" ]]; then
                cp -f "$RESOURCES_DIR/$TOOL/scripts/lib/AGENTS.md" "$SCRIPTS_DIR/lib/"
            else
                if [[ ! -f "$SCRIPTS_DIR/lib/AGENTS.md" ]]; then
                    cp "$RESOURCES_DIR/$TOOL/scripts/lib/AGENTS.md" "$SCRIPTS_DIR/lib/"
                fi
            fi
        fi
        
        LIB_COUNT=$(find "$RESOURCES_DIR/$TOOL/scripts/lib" -mindepth 1 -maxdepth 1 -type f -name "osx-*" 2>/dev/null | wc -l)
        
        if [[ $LIB_COUNT -gt 0 ]]; then
            if [[ "$COMMAND" == "update" ]]; then
                cp -f "$RESOURCES_DIR/$TOOL/scripts/lib"/osx-* "$SCRIPTS_DIR/lib/"
                chmod +x "$SCRIPTS_DIR/lib"/osx-*
                
                log_success "Deployed $LIB_COUNT lib script(s) to $TOOL"
                echo "  Target: $TARGET_DIR/scripts/lib/"
            else
                NEW_LIB_COUNT=0
                while IFS= read -r -d '' lib_file; do
                    lib_name=$(basename "$lib_file")
                    if [[ ! -f "$SCRIPTS_DIR/lib/$lib_name" ]]; then
                        cp "$lib_file" "$SCRIPTS_DIR/lib/"
                        chmod +x "$SCRIPTS_DIR/lib/$lib_name"
                        NEW_LIB_COUNT=$((NEW_LIB_COUNT + 1))
                    fi
                done < <(find "$RESOURCES_DIR/$TOOL/scripts/lib" -mindepth 1 -maxdepth 1 -type f -name "osx-*" -print0 2>/dev/null)
                
                if [[ $NEW_LIB_COUNT -gt 0 ]]; then
                    log_success "Deployed $NEW_LIB_COUNT lib script(s) to $TOOL"
                    echo "  Target: $TARGET_DIR/scripts/lib/"
                fi
            fi
        fi
    fi
fi

AGENTS_SOURCE="$RESOURCES_DIR/$TOOL/agents"
AGENTS_TARGET="$FULL_PATH/agents"
if [[ -d "$AGENTS_SOURCE" ]]; then
    mkdir -p "$AGENTS_TARGET"
    AGENT_COUNT=$(find "$AGENTS_SOURCE" -mindepth 1 -maxdepth 1 -type f -name "*.md" 2>/dev/null | wc -l)
    
    if [[ $AGENT_COUNT -gt 0 ]]; then
        cp -f "$AGENTS_SOURCE"/*.md "$AGENTS_TARGET/"
        log_success "Copied $AGENT_COUNT agent definition(s) to $TOOL"
        echo "  Target: $TARGET_DIR/agents/"
    fi
fi

TARGET_MANIFEST="$FULL_PATH/manifest.json"
if [[ -f "$SOURCE_MANIFEST" ]]; then
    jq --arg v "$GIT_VERSION" '.version = $v' "$SOURCE_MANIFEST" > "$TARGET_MANIFEST"
    log_success "Copied manifest to $TARGET_DIR/manifest.json (v$GIT_VERSION)"
    
    validate_deployment "$FULL_PATH" "$(cat "$SOURCE_MANIFEST")"
fi

if [[ -f "$SCRIPTS_DIR/osx-orchestrate" ]]; then
    if [[ "$COMMAND" == "update" ]]; then
        update_gitignore "true"
    else
        update_gitignore "false"
    fi
fi

if [[ "$WITH_CORE" == "true" ]]; then
    deploy_core "$TOOL"
fi

exit 0
