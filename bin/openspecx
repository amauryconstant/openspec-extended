#!/usr/bin/env bash
# OpenSpec-extended - Installer for OpenSpec resources
# Usage: openspecx <install|update> <tool>

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
readonly SCRIPT_DIR
readonly RESOURCES_DIR="$SCRIPT_DIR/../resources"

readonly COLOR_GREEN='\033[0;32m'
readonly COLOR_RED='\033[0;31m'
readonly COLOR_YELLOW='\033[0;33m'
readonly COLOR_RESET='\033[0m'

get_tool_dir() {
    case "$1" in
        opencode) echo ".opencode" ;;
        claude)   echo ".claude" ;;
        *)        return 1 ;;
    esac
}

log_success() {
    echo -e "${COLOR_GREEN}✓${COLOR_RESET} $*"
}

log_error() {
    echo -e "${COLOR_RED}✗${COLOR_RESET} $*" >&2
}

log_warn() {
    echo -e "${COLOR_YELLOW}!${COLOR_RESET} $*"
}

get_git_tag() {
    git -C "$SCRIPT_DIR" describe --tags --abbrev=0 2>/dev/null | sed 's/^v//' || echo "0.0.0"
}

copy_skills() {
    local source_dir="$1"
    local target_dir="$2"
    local force="$3"
    
    local processed_count=0
    local skipped_count=0
    
    while IFS= read -r -d '' skill_dir; do
        local skill_name
        skill_name=$(basename "$skill_dir")
        local target_skill_dir="$target_dir/$skill_name"
        
        if [[ "$force" == "true" ]]; then
            cp -r "$skill_dir" "$target_dir/"
            processed_count=$((processed_count + 1))
        else
            if [[ -d "$target_skill_dir" ]]; then
                skipped_count=$((skipped_count + 1))
            else
                cp -r "$skill_dir" "$target_dir/"
                processed_count=$((processed_count + 1))
            fi
        fi
    done < <(find "$source_dir" -mindepth 1 -maxdepth 1 -type d -print0 2>/dev/null)
    
    echo "$processed_count:$skipped_count"
}

show_usage() {
    log_error "Usage: openspecx <command> <tool> [--with-core]"
    echo
    echo "Commands:"
    echo "  install <tool>  Add missing resources (skip existing)"
    echo "  update <tool>   Force update all resources (overwrite existing)"
    echo
    echo "Available tools: opencode, claude"
    echo
    echo "Options:"
    echo "  --with-core     Also deploy core OpenSpec skills from openspec-core/"
}

update_gitignore() {
    local force="$1"
    local gitignore="$(pwd)/.gitignore"
    local marker_start="# BEGIN OpenSpec autonomous workflow state"
    local marker_end="# END OpenSpec autonomous workflow state"
    
    if [[ ! -f "$gitignore" ]]; then
        touch "$gitignore"
    fi
    
    if [[ "$force" == "true" ]]; then
        local content
        content=$(sed "/^$marker_start$/,/^$marker_end$/d" "$gitignore" 2>/dev/null || cat "$gitignore")
        echo "$content" > "$gitignore"
    elif grep -qF "$marker_start" "$gitignore" 2>/dev/null; then
        return 0
    fi
    
    {
        echo ""
        echo "$marker_start"
        echo ".openspec-baseline.json"
        echo "openspec/changes/*/state.json"
        echo "openspec/changes/*/complete.json"
        echo "openspec/changes/*/iterations.json"
        echo "openspec/changes/*/decision-log.json"
        echo "openspec/changes/*/verification-report.md"
        echo "openspec/changes/*/reflections.md"
        echo "openspec/changes/*/test-compliance-report.md"
        echo "$marker_end"
    } >> "$gitignore"
    
    log_success "Added OpenSpec state files to .gitignore"
}

deploy_core() {
    local tool="$1"
    local core_dir="$SCRIPT_DIR/../openspec-core/.$tool"
    local target_base="$(pwd)/.$tool"
    
    if [[ ! -d "$core_dir" ]]; then
        echo "  Core directory not found: openspec-core/.$tool"
        return 1
    fi
    
    local core_count=0
    
    if [[ -d "$core_dir/skills" ]]; then
        mkdir -p "$target_base/skills"
        for skill_dir in "$core_dir/skills"/*; do
            if [[ -d "$skill_dir" ]]; then
                local skill_name=$(basename "$skill_dir")
                cp -r "$skill_dir" "$target_base/skills/"
                core_count=$((core_count + 1))
            fi
        done
    fi
    
    if [[ -d "$core_dir/commands" ]]; then
        mkdir -p "$target_base/commands"
        if [[ -d "$core_dir/commands/opsx" ]]; then
            mkdir -p "$target_base/commands/opsx"
            cp -r "$core_dir/commands/opsx"/* "$target_base/commands/opsx/" 2>/dev/null || true
        else
            cp -r "$core_dir/commands"/* "$target_base/commands/" 2>/dev/null || true
        fi
        core_count=$((core_count + 1))
    fi
    
    if [[ $core_count -gt 0 ]]; then
        log_success "Deployed core skills/commands to $tool"
    fi
}

validate_deployment() {
    local target_dir="$1"
    local manifest="$2"
    local warnings=0
    
    if [[ ! -d "$target_dir" ]]; then
        return 0
    fi
    
    local resource_names
    resource_names=$(echo "$manifest" | jq -r '.resources | to_entries[] | .value | keys[]' 2>/dev/null | sort -u || true)
    
    for resource_name in $resource_names; do
        local found=false
        
        if [[ -d "$target_dir/skills/$resource_name" ]]; then
            found=true
        elif [[ -f "$target_dir/agents/$resource_name.md" ]]; then
            found=true
        elif [[ -f "$target_dir/commands/$resource_name.md" ]]; then
            found=true
        elif [[ -f "$target_dir/commands/opsx/${resource_name#opsx-}.md" ]]; then
            found=true
        elif [[ -f "$target_dir/scripts/$resource_name" ]]; then
            found=true
        elif [[ -f "$target_dir/scripts/lib/$resource_name" ]]; then
            found=true
        fi
        
        if [[ "$found" == "false" ]]; then
            log_warn "Resource '$resource_name' in manifest but not deployed"
            warnings=$((warnings + 1))
        fi
    done
    
    if [[ $warnings -gt 0 ]]; then
        echo "  Validation: $warnings warning(s)"
    fi
}

if [[ $# -lt 2 ]]; then
    show_usage
    exit 1
fi

COMMAND="$1"
TOOL="$2"
WITH_CORE=false

shift 2
while [[ $# -gt 0 ]]; do
    case "$1" in
        --with-core)
            WITH_CORE=true
            shift
            ;;
        *)
            log_error "Unknown option: $1"
            show_usage
            exit 1
            ;;
    esac
done

if [[ "$COMMAND" != "install" && "$COMMAND" != "update" ]]; then
    log_error "Unknown command: $COMMAND"
    echo
    echo "Available commands: install, update"
    echo
    show_usage
    exit 1
fi

_target_dir=$(get_tool_dir "$TOOL")
case $? in
    0) TARGET_DIR="$_target_dir" ;;
    *) 
        log_error "Unknown tool: $TOOL"
        echo "  Available tools: opencode, claude"
        exit 1
        ;;
esac

GIT_VERSION=$(get_git_tag)
FULL_PATH="$(pwd)/$TARGET_DIR"
SOURCE_MANIFEST="$RESOURCES_DIR/$TOOL/manifest.json"

mkdir -p "$FULL_PATH/skills"

if [[ -d "$RESOURCES_DIR/$TOOL/skills" ]]; then
    if [[ "$COMMAND" == "update" ]]; then
        RESULT=$(copy_skills "$RESOURCES_DIR/$TOOL/skills" "$FULL_PATH/skills" "true")
        UPDATED_COUNT="${RESULT%%:*}"
        
        if [[ $UPDATED_COUNT -gt 0 ]]; then
            log_success "Updated $UPDATED_COUNT skill(s) in $TOOL (v$GIT_VERSION)"
            echo "  Target: $TARGET_DIR/skills"
        else
            echo "No skills found in resources/$TOOL/skills/"
        fi
    else
        RESULT=$(copy_skills "$RESOURCES_DIR/$TOOL/skills" "$FULL_PATH/skills" "false")
        INSTALLED_COUNT="${RESULT%%:*}"
        SKIPPED_COUNT="${RESULT##*:}"
        
        if [[ $INSTALLED_COUNT -gt 0 ]]; then
            log_success "Installed $INSTALLED_COUNT skill(s) to $TOOL (v$GIT_VERSION)"
            echo "  Target: $TARGET_DIR/skills"
        fi
        
        if [[ $SKIPPED_COUNT -gt 0 ]]; then
            echo "  Skipped $SKIPPED_COUNT existing skill(s)"
        fi
        
        if [[ $INSTALLED_COUNT -eq 0 && $SKIPPED_COUNT -eq 0 ]]; then
            echo "No skills found in resources/$TOOL/skills/"
        fi
    fi
else
    echo "resources/$TOOL/skills/ directory not found"
fi

COMMANDS_DIR="$FULL_PATH/commands"
if [[ -d "$RESOURCES_DIR/$TOOL/commands" ]]; then
    mkdir -p "$COMMANDS_DIR"
    
    FLAT_COMMAND_COUNT=$(find "$RESOURCES_DIR/$TOOL/commands" -mindepth 1 -maxdepth 1 -type f -name "*.md" 2>/dev/null | wc -l)
    if [[ $FLAT_COMMAND_COUNT -gt 0 ]]; then
        cp -f "$RESOURCES_DIR/$TOOL/commands"/*.md "$COMMANDS_DIR/"
        log_success "Copied $FLAT_COMMAND_COUNT command(s) to $TOOL"
        echo "  Target: $TARGET_DIR/commands/"
    fi
    
    for subdir in "$RESOURCES_DIR/$TOOL/commands"/*/; do
        if [[ -d "$subdir" ]]; then
            subdir_name=$(basename "$subdir")
            NESTED_COMMAND_COUNT=$(find "$subdir" -mindepth 1 -maxdepth 1 -type f -name "*.md" 2>/dev/null | wc -l)
            if [[ $NESTED_COMMAND_COUNT -gt 0 ]]; then
                mkdir -p "$COMMANDS_DIR/$subdir_name"
                cp -f "$subdir"*.md "$COMMANDS_DIR/$subdir_name/"
                log_success "Copied $NESTED_COMMAND_COUNT command(s) to $TOOL/$subdir_name"
                echo "  Target: $TARGET_DIR/commands/$subdir_name/"
            fi
        fi
    done
fi

SCRIPTS_DIR="$FULL_PATH/scripts"
if [[ -d "$RESOURCES_DIR/$TOOL/scripts" ]]; then
    mkdir -p "$SCRIPTS_DIR"
    SCRIPT_COUNT=$(find "$RESOURCES_DIR/$TOOL/scripts" -mindepth 1 -maxdepth 1 -type f 2>/dev/null | wc -l)
    
    if [[ $SCRIPT_COUNT -gt 0 ]]; then
        if [[ "$COMMAND" == "update" ]]; then
            find "$RESOURCES_DIR/$TOOL/scripts" -mindepth 1 -maxdepth 1 -type f -exec cp -f {} "$SCRIPTS_DIR/" \;
            find "$SCRIPTS_DIR" -type f -name "*.sh" -exec chmod +x {} \;
            if [[ -f "$SCRIPTS_DIR/openspec-auto" ]]; then
                chmod +x "$SCRIPTS_DIR/openspec-auto"
            fi
            log_success "Updated $SCRIPT_COUNT script(s) in $TOOL"
            echo "  Target: $TARGET_DIR/scripts/"
        else
            NEW_SCRIPT_COUNT=0
            while IFS= read -r -d '' script_file; do
                script_name=$(basename "$script_file")
                if [[ ! -f "$SCRIPTS_DIR/$script_name" ]]; then
                    cp "$script_file" "$SCRIPTS_DIR/"
                    if [[ "$script_name" == *.sh ]]; then
                        chmod +x "$SCRIPTS_DIR/$script_name"
                    fi
                    if [[ "$script_name" == "openspec-auto" ]]; then
                        chmod +x "$SCRIPTS_DIR/$script_name"
                    fi
                    NEW_SCRIPT_COUNT=$((NEW_SCRIPT_COUNT + 1))
                fi
            done < <(find "$RESOURCES_DIR/$TOOL/scripts" -mindepth 1 -maxdepth 1 -type f -print0)
            
            if [[ $NEW_SCRIPT_COUNT -gt 0 ]]; then
                log_success "Installed $NEW_SCRIPT_COUNT script(s) to $TOOL"
                echo "  Target: $TARGET_DIR/scripts/"
            fi
        fi
    fi
    
    if [[ -d "$RESOURCES_DIR/$TOOL/scripts/lib" ]]; then
        mkdir -p "$SCRIPTS_DIR/lib"
        LIB_COUNT=$(find "$RESOURCES_DIR/$TOOL/scripts/lib" -mindepth 1 -maxdepth 1 -type f -name "osc-*" 2>/dev/null | wc -l)
        
        if [[ $LIB_COUNT -gt 0 ]]; then
            cp -f "$RESOURCES_DIR/$TOOL/scripts/lib"/osc-* "$SCRIPTS_DIR/lib/"
            chmod +x "$SCRIPTS_DIR/lib"/osc-*
            
            log_success "Deployed $LIB_COUNT lib script(s) to $TOOL"
            echo "  Target: $TARGET_DIR/scripts/lib/"
        fi
    fi
fi

AGENTS_SOURCE="$RESOURCES_DIR/$TOOL/agents"
AGENTS_TARGET="$FULL_PATH/agents"
if [[ -d "$AGENTS_SOURCE" ]]; then
    mkdir -p "$AGENTS_TARGET"
    AGENT_COUNT=$(find "$AGENTS_SOURCE" -mindepth 1 -maxdepth 1 -type f -name "*.md" 2>/dev/null | wc -l)
    
    if [[ $AGENT_COUNT -gt 0 ]]; then
        cp -f "$AGENTS_SOURCE"/*.md "$AGENTS_TARGET/"
        log_success "Copied $AGENT_COUNT agent definition(s) to $TOOL"
        echo "  Target: $TARGET_DIR/agents/"
    fi
fi

TARGET_MANIFEST="$FULL_PATH/manifest.json"
if [[ -f "$SOURCE_MANIFEST" ]]; then
    jq --arg v "$GIT_VERSION" '.version = $v' "$SOURCE_MANIFEST" > "$TARGET_MANIFEST"
    log_success "Copied manifest to $TARGET_DIR/manifest.json (v$GIT_VERSION)"
    
    validate_deployment "$FULL_PATH" "$(cat "$SOURCE_MANIFEST")"
fi

if [[ -f "$SCRIPTS_DIR/openspec-auto" ]]; then
    if [[ "$COMMAND" == "update" ]]; then
        update_gitignore "true"
    else
        update_gitignore "false"
    fi
fi

if [[ "$WITH_CORE" == "true" ]]; then
    deploy_core "$TOOL"
fi

exit 0
