#!/bin/bash
# OpenSpec-extended - Simplified installer for OpenSpec skills
# Usage: openspecx <install|update> <tool>

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
readonly SCRIPT_DIR
readonly RESOURCES_DIR="$SCRIPT_DIR/../resources"

readonly COLOR_GREEN='\033[0;32m'
readonly COLOR_RED='\033[0;31m'
readonly COLOR_RESET='\033[0m'

declare -A TOOL_DIRS=(
    ["opencode"]=".opencode"
    ["claude"]=".claude"
)

log_success() {
    echo -e "${COLOR_GREEN}✓${COLOR_RESET} $*"
}

log_error() {
    echo -e "${COLOR_RED}✗${COLOR_RESET} $*" >&2
}

validate_version() {
    local version="$1"
    local file="$2"
    
    if [[ ! "$version" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
        log_error "Invalid version format in $file: '$version' (expected semver: X.Y.Z)"
        exit 1
    fi
}

get_script_version() {
    local version
    version=$(git -C "$SCRIPT_DIR" describe --tags --abbrev=0 2>/dev/null | sed 's/^v//' || echo "")
    if [[ -n "$version" ]]; then
        echo "$version"
    else
        echo "No version found"
    fi
}

inject_generated_by() {
    local file="$1"
    local version="$2"
    
    if [[ ! -f "$file" ]]; then
        return
    fi
    
    local content
    content=$(cat "$file")
    
    # Check if file has YAML frontmatter
    if ! echo "$content" | head -1 | grep -q "^---$"; then
        return
    fi
    
    # Extract and validate existing version if present
    local existing_version
    existing_version=$(echo "$content" | grep -E "^version:" | head -1 | sed 's/version: *"\?//' | sed 's/"\?$//' || true)
    if [[ -n "$existing_version" ]]; then
        validate_version "$existing_version" "$file"
    fi
    
    # Also check for version in metadata block (skills)
    local metadata_version
    metadata_version=$(echo "$content" | grep -E "^  version:" | head -1 | sed 's/  version: *"\?//' | sed 's/"\?$//' || true)
    if [[ -n "$metadata_version" ]]; then
        validate_version "$metadata_version" "$file"
    fi
    
    local new_content
    
    # Handle files with metadata: block (skills)
    if echo "$content" | grep -q "^metadata:"; then
        if echo "$content" | grep -q "^  generatedBy:"; then
            new_content=$(echo "$content" | sed "s/^  generatedBy: \".*\"/  generatedBy: \"$version\"/")
        else
            new_content=$(echo "$content" | sed "/^metadata:/a\\  generatedBy: \"$version\"")
        fi
    # Handle files with direct version field (commands, agents)
    elif echo "$content" | grep -q "^version:"; then
        if echo "$content" | grep -q "^generatedBy:"; then
            new_content=$(echo "$content" | sed "s/^generatedBy: \".*\"/generatedBy: \"$version\"/")
        else
            # Insert generatedBy after version line
            new_content=$(echo "$content" | sed '/^version:/a\generatedBy: "'"$version"'"')
        fi
    # Handle files with frontmatter but no version (fallback)
    else
        if echo "$content" | grep -q "^generatedBy:"; then
            new_content=$(echo "$content" | sed "s/^generatedBy: \".*\"/generatedBy: \"$version\"/")
        else
            # Insert generatedBy after first --- (opening frontmatter)
            new_content=$(echo "$content" | sed '1,/^---$/s/^---$/---\ngeneratedBy: "'"$version"'"/')
        fi
    fi
    
    echo "$new_content" > "$file"
}

copy_and_process_skills() {
    local source_dir="$1"
    local target_dir="$2"
    local version="$3"
    local force="$4"
    
    local processed_count=0
    local skipped_count=0
    
    while IFS= read -r -d '' skill_dir; do
        local skill_name
        skill_name=$(basename "$skill_dir")
        local target_skill_dir="$target_dir/$skill_name"
        
        if [[ "$force" == "true" ]]; then
            cp -r "$skill_dir" "$target_dir/"
            
            local skill_file="$target_skill_dir/SKILL.md"
            if [[ -f "$skill_file" ]]; then
                inject_generated_by "$skill_file" "$version"
            fi
            
            processed_count=$((processed_count + 1))
        else
            if [[ -d "$target_skill_dir" ]]; then
                skipped_count=$((skipped_count + 1))
            else
                cp -r "$skill_dir" "$target_dir/"
                
                local skill_file="$target_skill_dir/SKILL.md"
                if [[ -f "$skill_file" ]]; then
                    inject_generated_by "$skill_file" "$version"
                fi
                
                processed_count=$((processed_count + 1))
            fi
        fi
    done < <(find "$source_dir" -mindepth 1 -maxdepth 1 -type d -print0)
    
    echo "$processed_count:$skipped_count"
}

show_usage() {
    log_error "Usage: openspecx <command> <tool> [--with-core]"
    echo
    echo "Commands:"
    echo "  install <tool>  Add missing skills (skip existing)"
    echo "  update <tool>   Force update all skills (overwrite existing)"
    echo
    echo "Available tools: opencode, claude"
    echo
    echo "Options:"
    echo "  --with-core     Also deploy core OpenSpec skills from openspec-core/"
}

update_gitignore() {
    local gitignore="$(pwd)/.gitignore"
    local marker_start="# BEGIN OpenSpec autonomous workflow state"
    local marker_end="# END OpenSpec autonomous workflow state"
    
    if [[ ! -f "$gitignore" ]]; then
        touch "$gitignore"
    fi
    
    if grep -qF "$marker_start" "$gitignore" 2>/dev/null; then
        return 0
    fi
    
    {
        echo ""
        echo "$marker_start"
        echo ".openspec-baseline.json"
        echo "openspec/changes/**/state.json"
        echo "openspec/changes/**/complete.json"
        echo "openspec/changes/**/iterations.json"
        echo "openspec/changes/**/decision-log.md"
        echo "$marker_end"
    } >> "$gitignore"
    
    log_success "Added OpenSpec state files to .gitignore"
}

deploy_core() {
    local tool="$1"
    local core_dir="$SCRIPT_DIR/../openspec-core/.$tool"
    local target_base="$(pwd)/.$tool"
    
    if [[ ! -d "$core_dir" ]]; then
        echo "  Core directory not found: openspec-core/.$tool"
        return 1
    fi
    
    local core_count=0
    
    if [[ -d "$core_dir/skills" ]]; then
        mkdir -p "$target_base/skills"
        for skill_dir in "$core_dir/skills"/*; do
            if [[ -d "$skill_dir" ]]; then
                local skill_name=$(basename "$skill_dir")
                cp -r "$skill_dir" "$target_base/skills/"
                core_count=$((core_count + 1))
            fi
        done
    fi
    
    if [[ -d "$core_dir/commands" ]]; then
        mkdir -p "$target_base/commands"
        if [[ -d "$core_dir/commands/opsx" ]]; then
            mkdir -p "$target_base/commands/opsx"
            cp -r "$core_dir/commands/opsx"/* "$target_base/commands/opsx/" 2>/dev/null || true
        else
            cp -r "$core_dir/commands"/* "$target_base/commands/" 2>/dev/null || true
        fi
        core_count=$((core_count + 1))
    fi
    
    if [[ $core_count -gt 0 ]]; then
        log_success "Deployed core skills/commands to $tool"
    fi
}

if [[ $# -lt 2 ]]; then
    show_usage
    exit 1
fi

COMMAND="$1"
TOOL="$2"
WITH_CORE=false

shift 2
while [[ $# -gt 0 ]]; do
    case "$1" in
        --with-core)
            WITH_CORE=true
            shift
            ;;
        *)
            log_error "Unknown option: $1"
            show_usage
            exit 1
            ;;
    esac
done

if [[ "$COMMAND" != "install" && "$COMMAND" != "update" ]]; then
    log_error "Unknown command: $COMMAND"
    echo
    echo "Available commands: install, update"
    echo
    show_usage
    exit 1
fi

if [[ -z "${TOOL_DIRS[$TOOL]:-}" ]]; then
    log_error "Unknown tool: $TOOL"
    echo "  Available tools: opencode, claude"
    exit 1
fi

SCRIPT_VERSION=$(get_script_version)
TARGET_DIR="${TOOL_DIRS[$TOOL]}"
FULL_PATH="$(pwd)/$TARGET_DIR"

mkdir -p "$FULL_PATH/skills"

if [[ -d "$RESOURCES_DIR/$TOOL/skills" ]]; then
    if [[ "$COMMAND" == "update" ]]; then
        RESULT=$(copy_and_process_skills "$RESOURCES_DIR/$TOOL/skills" "$FULL_PATH/skills" "$SCRIPT_VERSION" "true")
        UPDATED_COUNT="${RESULT%%:*}"
        
        if [[ $UPDATED_COUNT -gt 0 ]]; then
            log_success "Updated $UPDATED_COUNT skill(s) in $TOOL (v$SCRIPT_VERSION)"
            echo "  Target: $TARGET_DIR/skills"
        else
            echo "No skills found in resources/$TOOL/skills/"
        fi
    else
        RESULT=$(copy_and_process_skills "$RESOURCES_DIR/$TOOL/skills" "$FULL_PATH/skills" "$SCRIPT_VERSION" "false")
        INSTALLED_COUNT="${RESULT%%:*}"
        SKIPPED_COUNT="${RESULT##*:}"
        
        if [[ $INSTALLED_COUNT -gt 0 ]]; then
            log_success "Installed $INSTALLED_COUNT skill(s) to $TOOL (v$SCRIPT_VERSION)"
            echo "  Target: $TARGET_DIR/skills"
        fi
        
        if [[ $SKIPPED_COUNT -gt 0 ]]; then
            echo "  Skipped $SKIPPED_COUNT existing skill(s)"
        fi
        
        if [[ $INSTALLED_COUNT -eq 0 && $SKIPPED_COUNT -eq 0 ]]; then
            echo "No skills found in resources/$TOOL/skills/"
        fi
    fi
else
    echo "resources/$TOOL/skills/ directory not found"
fi

COMMANDS_DIR="$FULL_PATH/commands"
if [[ -d "$RESOURCES_DIR/$TOOL/commands" ]]; then
    mkdir -p "$COMMANDS_DIR"
    
    COMMAND_COUNT=$(find "$RESOURCES_DIR/$TOOL/commands" -mindepth 1 -maxdepth 1 -type f -name "*.md" 2>/dev/null | wc -l)
    if [[ $COMMAND_COUNT -gt 0 ]]; then
        cp -r "$RESOURCES_DIR/$TOOL/commands"/*.md "$COMMANDS_DIR/"
        
        # Inject generatedBy into each command file
        for cmd_file in "$COMMANDS_DIR"/*.md; do
            if [[ -f "$cmd_file" ]]; then
                inject_generated_by "$cmd_file" "$SCRIPT_VERSION"
            fi
        done
        
        log_success "Copied $COMMAND_COUNT command(s) to $TOOL (v$SCRIPT_VERSION)"
        echo "  Target: $TARGET_DIR/commands/"
    fi
fi

# Handle scripts
SCRIPTS_DIR="$FULL_PATH/scripts"
if [[ -d "$RESOURCES_DIR/$TOOL/scripts" ]]; then
    mkdir -p "$SCRIPTS_DIR"
    SCRIPT_COUNT=$(find "$RESOURCES_DIR/$TOOL/scripts" -mindepth 1 -maxdepth 1 -type f 2>/dev/null | wc -l)
    
    if [[ $SCRIPT_COUNT -gt 0 ]]; then
        if [[ "$COMMAND" == "update" ]]; then
            cp -f "$RESOURCES_DIR/$TOOL/scripts"/* "$SCRIPTS_DIR/"
            # Ensure shell scripts are executable
            find "$SCRIPTS_DIR" -type f -name "*.sh" -exec chmod +x {} \;
            # Ensure openspec-auto is executable (no .sh extension)
            if [[ -f "$SCRIPTS_DIR/openspec-auto" ]]; then
                chmod +x "$SCRIPTS_DIR/openspec-auto"
            fi
            log_success "Updated $SCRIPT_COUNT script(s) in $TOOL"
            echo "  Target: $TARGET_DIR/scripts/"
        else
            NEW_SCRIPT_COUNT=0
            while IFS= read -r -d '' script_file; do
                script_name=$(basename "$script_file")
                if [[ ! -f "$SCRIPTS_DIR/$script_name" ]]; then
                    cp "$script_file" "$SCRIPTS_DIR/"
                    # Set executable for shell scripts
                    if [[ "$script_name" == *.sh ]]; then
                        chmod +x "$SCRIPTS_DIR/$script_name"
                    fi
                    # Set executable for openspec-auto
                    if [[ "$script_name" == "openspec-auto" ]]; then
                        chmod +x "$SCRIPTS_DIR/$script_name"
                    fi
                    NEW_SCRIPT_COUNT=$((NEW_SCRIPT_COUNT + 1))
                fi
            done < <(find "$RESOURCES_DIR/$TOOL/scripts" -mindepth 1 -maxdepth 1 -type f -print0)
            
            if [[ $NEW_SCRIPT_COUNT -gt 0 ]]; then
                log_success "Installed $NEW_SCRIPT_COUNT script(s) to $TOOL"
                echo "  Target: $TARGET_DIR/scripts/"
            fi
        fi
    fi
    
    # Handle scripts/lib subdirectory (helper utilities)
    if [[ -d "$RESOURCES_DIR/$TOOL/scripts/lib" ]]; then
        mkdir -p "$SCRIPTS_DIR/lib"
        LIB_COUNT=$(find "$RESOURCES_DIR/$TOOL/scripts/lib" -mindepth 1 -maxdepth 1 -type f -name "osc-*" 2>/dev/null | wc -l)
        
        if [[ $LIB_COUNT -gt 0 ]]; then
            # Copy lib scripts
            cp -f "$RESOURCES_DIR/$TOOL/scripts/lib"/osc-* "$SCRIPTS_DIR/lib/"
            chmod +x "$SCRIPTS_DIR/lib"/osc-*
            
            # Copy MANIFEST.json if exists
            if [[ -f "$RESOURCES_DIR/$TOOL/scripts/lib/MANIFEST.json" ]]; then
                cp -f "$RESOURCES_DIR/$TOOL/scripts/lib/MANIFEST.json" "$SCRIPTS_DIR/lib/"
            fi
            
            log_success "Deployed $LIB_COUNT lib script(s) to $TOOL"
            echo "  Target: $TARGET_DIR/scripts/lib/"
        fi
    fi
fi

# Handle agents directory (for phase-specific agent definitions with embedded workflows)
# Always copy agents on install/update since they're definitions that may have been updated
AGENTS_SOURCE="$RESOURCES_DIR/$TOOL/agents"
AGENTS_TARGET="$FULL_PATH/agents"
if [[ -d "$AGENTS_SOURCE" ]]; then
    mkdir -p "$AGENTS_TARGET"
    AGENT_COUNT=$(find "$AGENTS_SOURCE" -mindepth 1 -maxdepth 1 -type f -name "*.md" 2>/dev/null | wc -l)
    
    if [[ $AGENT_COUNT -gt 0 ]]; then
        cp -f "$AGENTS_SOURCE"/*.md "$AGENTS_TARGET/"
        
        # Inject generatedBy into each agent file
        for agent_file in "$AGENTS_TARGET"/*.md; do
            if [[ -f "$agent_file" ]]; then
                inject_generated_by "$agent_file" "$SCRIPT_VERSION"
            fi
        done
        
        log_success "Copied $AGENT_COUNT agent definition(s) to $TOOL (v$SCRIPT_VERSION)"
        echo "  Target: $TARGET_DIR/agents/"
    fi
fi

# Update .gitignore if openspec-auto was installed
if [[ -f "$SCRIPTS_DIR/openspec-auto" ]]; then
    update_gitignore
fi

# Deploy core skills if requested
if [[ "$WITH_CORE" == "true" ]]; then
    deploy_core "$TOOL"
fi

exit 0
