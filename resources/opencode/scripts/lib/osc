def cmd_iterations_get(args):
    """Get iteration history."""
    change_dir = find_change_dir(args.change)
    iterations_file = change_dir / "iterations.json"

    if not iterations_file.exists():
        output({"count": 0, "iterations": []})
        return

    iterations = read_json_array(iterations_file)
    iteration_nums = [i.get("iteration") for i in iterations if "iteration" in i]
    output({"count": len(iterations), "iterations": iteration_nums})


def cmd_iterations_append(args):
    """Append iteration entry (from stdin or CLI args)."""
    change_dir = find_change_dir(args.change)
    iterations_file = change_dir / "iterations.json"

    # Build entry from stdin or args
    stdin_data = read_stdin_json()
    if stdin_data is not None:
        entry = stdin_data
    else:
        if args.iteration is None or args.phase is None:
            error(
                "missing_field",
                "iteration and phase required (via --iteration and --phase or stdin)",
            )
        entry = {"iteration": args.iteration, "phase": args.phase}
        if args.summary:
            entry["summary"] = args.summary
        if args.status:
            entry["status"] = args.status
        if args.issues:
            try:
                entry["issues"] = json.loads(args.issues)
            except json.JSONDecodeError:
                error("invalid_json", "issues must be valid JSON")
        if args.artifacts_modified:
            try:
                entry["artifacts_modified"] = json.loads(args.artifacts_modified)
            except json.JSONDecodeError:
                error("invalid_json", "artifacts_modified must be valid JSON")
        if args.decisions:
            try:
                entry["decisions"] = json.loads(args.decisions)
            except json.JSONDecodeError:
                error("invalid_json", "decisions must be valid JSON")
        if args.errors:
            try:
                entry["errors"] = json.loads(args.errors)
            except json.JSONDecodeError:
                error("invalid_json", "errors must be valid JSON")

    # Validate required fields
    if "iteration" not in entry:
        error("missing_field", "iteration field is required")

    # Add timestamp if not present
    entry.setdefault("timestamp", get_timestamp())

    total = append_to_json_array(iterations_file, entry)
    output(
        {
            "success": True,
            "iteration": entry["iteration"],
            "total_count": total,
        }
    )


# =============================================================================
# Log Domain
# =============================================================================


def cmd_log_get(args):
    """Get decision log."""
    change_dir = find_change_dir(args.change)
    log_file = change_dir / "decision-log.json"

    if not log_file.exists():
        output({"count": 0, "entries": []})
        return

    entries = read_json_array(log_file)
    output({"count": len(entries), "entries": entries})


def cmd_log_append(args):
    """Append log entry (from stdin or CLI args)."""
    change_dir = find_change_dir(args.change)
    log_file = change_dir / "decision-log.json"

    # Build entry from stdin or args
    stdin_data = read_stdin_json()
    if stdin_data is not None:
        entry = stdin_data
    else:
        if args.phase is None or args.iteration is None:
            error(
                "missing_field",
                "phase and iteration required (via --phase and --iteration or stdin)",
            )
        entry = {"phase": args.phase, "iteration": args.iteration}
        if args.summary:
            entry["summary"] = args.summary
        if args.issues:
            try:
                entry["issues"] = json.loads(args.issues)
            except json.JSONDecodeError:
                error("invalid_json", "issues must be valid JSON")
        if args.artifacts_modified:
            try:
                entry["artifacts_modified"] = json.loads(args.artifacts_modified)
            except json.JSONDecodeError:
                error("invalid_json", "artifacts_modified must be valid JSON")
        if args.next_steps:
            try:
                entry["next_steps"] = json.loads(args.next_steps)
            except json.JSONDecodeError:
                error("invalid_json", "next_steps must be valid JSON")
        if args.decisions:
            try:
                entry["decisions"] = json.loads(args.decisions)
            except json.JSONDecodeError:
                error("invalid_json", "decisions must be valid JSON")
        if args.errors:
            try:
                entry["errors"] = json.loads(args.errors)
            except json.JSONDecodeError:
                error("invalid_json", "errors must be valid JSON")

    # Validate required fields
    if "phase" not in entry:
        error("missing_field", "phase field is required")
    if "iteration" not in entry:
        error("missing_field", "iteration field is required")

    # Get entry number and timestamp
    entries = read_json_array(log_file)
    entry_num = len(entries) + 1
    timestamp = get_timestamp()

    entry["entry"] = entry_num
    entry["timestamp"] = timestamp

    total = append_to_json_array(log_file, entry)
    output(
        {
            "success": True,
            "entry": entry_num,
            "phase": entry["phase"],
            "iteration": entry["iteration"],
            "timestamp": timestamp,
        }
    )


