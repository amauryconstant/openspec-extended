def cmd_complete_check(args):
    """Check if complete.json exists."""
    change_dir = find_change_dir(args.change)
    complete_file = change_dir / "complete.json"

    if not complete_file.exists():
        output({"exists": False})
        sys.exit(1)

    try:
        json.loads(complete_file.read_text())
        output({"exists": True})
    except json.JSONDecodeError:
        output({"exists": False, "error": "invalid_json"})
        sys.exit(1)


def cmd_complete_get(args):
    """Get completion status."""
    change_dir = find_change_dir(args.change)
    complete_file = change_dir / "complete.json"

    if not complete_file.exists():
        error("complete_not_found", "complete.json does not exist")

    try:
        data = json.loads(complete_file.read_text())
    except json.JSONDecodeError:
        error("invalid_json", "complete.json contains invalid JSON")

    result = {
        "status": data.get("status", "UNKNOWN"),
        "with_blocker": data.get("with_blocker", False),
    }
    if data.get("blocker_reason"):
        result["blocker_reason"] = data["blocker_reason"]

    output(result)


def cmd_complete_set(args):
    """Set completion status."""
    change_dir = find_change_dir(args.change)
    complete_file = change_dir / "complete.json"

    timestamp = get_timestamp()

    if args.status == "BLOCKED" and args.blocker_reason:
        data = {
            "status": args.status,
            "with_blocker": True,
            "blocker_reason": args.blocker_reason,
            "timestamp": timestamp,
        }
        write_json(complete_file, data)
        output(
            {
                "status": args.status,
                "with_blocker": True,
                "blocker_reason": args.blocker_reason,
            }
        )
    else:
        data = {
            "status": args.status,
            "with_blocker": False,
            "timestamp": timestamp,
        }
        write_json(complete_file, data)
        output({"status": args.status, "with_blocker": False})


