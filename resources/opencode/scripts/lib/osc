def cmd_validate_json(args):
    """Validate JSON file."""
    file_path = Path(args.file)

    if not file_path.exists():
        output(
            {
                "valid": False,
                "errors": [{"check": "json", "message": f"File not found: {args.file}"}],
            }
        )
        sys.exit(1)

    try:
        json.loads(file_path.read_text())
        output({"valid": True})
    except json.JSONDecodeError:
        output(
            {
                "valid": False,
                "errors": [
                    {"check": "json", "message": f"Invalid JSON in file: {args.file}"}
                ],
            }
        )
        sys.exit(1)


def cmd_validate_skills(args):
    """Validate required skills exist."""
    errors = []

    for skill in REQUIRED_SKILLS:
        skill_path = SKILLS_DIR / skill / "SKILL.md"
        if not skill_path.exists():
            errors.append({"check": "skills", "message": f"Missing skill: {skill}"})

    if errors:
        output({"valid": False, "errors": errors})
        sys.exit(1)

    output({"valid": True})


def cmd_validate_commands(args):
    """Validate required commands exist."""
    errors = []

    for phase in PHASES:
        cmd_name = PHASE_COMMANDS.get(phase)
        if cmd_name:
            cmd_path = COMMANDS_DIR / f"{cmd_name}.md"
            if not cmd_path.exists():
                errors.append(
                    {"check": "commands", "message": f"Missing command: {cmd_name}"}
                )

    if errors:
        output({"valid": False, "errors": errors})
        sys.exit(1)

    output({"valid": True})


def cmd_validate_change_dir(args):
    """Validate change directory structure."""
    change_path = Path(f"openspec/changes/{args.change}")
    errors = []

    if not change_path.is_dir():
        output(
            {
                "valid": False,
                "errors": [
                    {
                        "check": "change-dir",
                        "message": f"Change directory not found: {change_path}",
                    }
                ],
            }
        )
        sys.exit(1)

    required_files = ["tasks.md", "proposal.md", "design.md"]
    for file in required_files:
        if not (change_path / file).exists():
            errors.append(
                {"check": "change-dir", "message": f"Missing required file: {file}"}
            )

    specs_dir = change_path / "specs"
    if not specs_dir.is_dir() or not list(specs_dir.glob("*.md")):
        errors.append(
            {"check": "change-dir", "message": "No spec files found in specs/"}
        )

    if errors:
        output({"valid": False, "errors": errors})
        sys.exit(1)

    output({"valid": True})


def cmd_validate_archive(args):
    """Validate change is archived."""
    archive_dir = Path("openspec/changes/archive")
    archives = []

    if archive_dir.is_dir():
        for d in archive_dir.iterdir():
            if d.is_dir() and d.name.endswith(f"-{args.change}"):
                archives.append(d)

    if len(archives) == 0:
        output(
            {
                "valid": False,
                "errors": [{"check": "archive", "message": "Change not archived"}],
            }
        )
        sys.exit(1)

    if len(archives) > 1:
        output(
            {
                "valid": False,
                "errors": [
                    {
                        "check": "archive",
                        "message": f"Multiple archives found for change: {len(archives)}",
                    }
                ],
            }
        )
        sys.exit(1)

    output({"valid": True, "archive": str(archives[0])})


def cmd_validate_iterations(args):
    """Validate iterations.json exists and is valid."""
    try:
        change_dir = find_change_dir(args.change)
    except SystemExit:
        output(
            {
                "valid": False,
                "errors": [
                    {"check": "iterations", "message": "Change directory not found"}
                ],
            }
        )
        sys.exit(1)

    iterations_file = change_dir / "iterations.json"

    if not iterations_file.exists():
        output(
            {
                "valid": False,
                "errors": [
                    {"check": "iterations", "message": "iterations.json not found"}
                ],
            }
        )
        sys.exit(1)

    try:
        json.loads(iterations_file.read_text())
    except json.JSONDecodeError:
        output(
            {
                "valid": False,
                "errors": [
                    {
                        "check": "iterations",
                        "message": "iterations.json contains invalid JSON",
                    }
                ],
            }
        )
        sys.exit(1)

    output({"valid": True})


def cmd_validate_completion(args):
    """Validate all completion requirements."""
    errors = []

    try:
        change_dir = find_change_dir(args.change)
    except SystemExit:
        output(
            {
                "valid": False,
                "errors": [
                    {"check": "completion", "message": "Change directory not found"}
                ],
            }
        )
        sys.exit(1)

    # Check state.json
    state_file = change_dir / "state.json"
    if not state_file.exists():
        errors.append({"check": "completion", "message": "state.json not found"})
    else:
        try:
            json.loads(state_file.read_text())
        except json.JSONDecodeError:
            errors.append(
                {"check": "completion", "message": "state.json contains invalid JSON"}
            )

    # Check complete.json
    complete_file = change_dir / "complete.json"
    if not complete_file.exists():
        errors.append({"check": "completion", "message": "complete.json not found"})
    else:
        try:
            json.loads(complete_file.read_text())
        except json.JSONDecodeError:
            errors.append(
                {
                    "check": "completion",
                    "message": "complete.json contains invalid JSON",
                }
            )

    # Check iterations.json
    iterations_file = change_dir / "iterations.json"
    if not iterations_file.exists():
        errors.append(
            {"check": "completion", "message": "iterations.json not found"}
        )
    else:
        try:
            json.loads(iterations_file.read_text())
        except json.JSONDecodeError:
            errors.append(
                {
                    "check": "completion",
                    "message": "iterations.json contains invalid JSON",
                }
            )

    # Check decision-log.json
    log_file = change_dir / "decision-log.json"
    if not log_file.exists():
        errors.append(
            {"check": "completion", "message": "decision-log.json not found"}
        )

    # Check archive
    archive_dir = Path("openspec/changes/archive")
    archives = []
    if archive_dir.is_dir():
        for d in archive_dir.iterdir():
            if d.is_dir() and d.name.endswith(f"-{args.change}"):
                archives.append(d)

    if len(archives) == 0:
        errors.append(
            {"check": "completion", "message": "Archive validation failed"}
        )

    if errors:
        output({"valid": False, "errors": errors})
        sys.exit(1)

    output({"valid": True})


# =============================================================================
# Argument Parsing
# =============================================================================


def create_parser():
    version = get_version()
    parser = argparse.ArgumentParser(
        prog="osc",
        description="OpenSpec Change management tool",
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    parser.add_argument("--version", action="version", version=f"%(prog)s {version}")

    subparsers = parser.add_subparsers(dest="domain", help="Domain")

    # State domain
    state_parser = subparsers.add_parser("state", help="Phase and iteration state management")
    state_subparsers = state_parser.add_subparsers(dest="action", help="Action")

    # state get
    state_get = state_subparsers.add_parser("get", help="Get current state")
    state_get.add_argument("change", help="Change name")
    state_get.set_defaults(func=cmd_state_get)

    # state set-phase
    state_set_phase = state_subparsers.add_parser("set-phase", help="Set current phase")
    state_set_phase.add_argument("change", help="Change name")
    state_set_phase.add_argument("phase", help="Phase to set")
    state_set_phase.set_defaults(func=cmd_state_set_phase)

    # state complete
    state_complete = state_subparsers.add_parser("complete", help="Mark phase complete")
    state_complete.add_argument("change", help="Change name")
    state_complete.set_defaults(func=cmd_state_complete)

    # state transition
    state_transition = state_subparsers.add_parser(
        "transition", help="Set explicit transition target"
    )
    state_transition.add_argument("change", help="Change name")
    state_transition.add_argument("target", help="Target phase")
    state_transition.add_argument("reason", help="Transition reason")
    state_transition.add_argument("details", nargs="?", default=None, help="Optional details")
    state_transition.set_defaults(func=cmd_state_transition)

    # state clear-transition
    state_clear = state_subparsers.add_parser(
        "clear-transition", help="Clear transition field"
    )
    state_clear.add_argument("change", help="Change name")
    state_clear.set_defaults(func=cmd_state_clear_transition)

    # Iterations domain
    iter_parser = subparsers.add_parser("iterations", help="Iteration history tracking")
