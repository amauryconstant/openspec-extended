#!/usr/bin/env bash
#MISE description="Verify version bump when versioned files are modified"

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=/dev/null
source "$SCRIPT_DIR/lib/common.sh"

OUTPUT_FORMAT="table"
while [[ $# -gt 0 ]]; do
  case "$1" in
    --json) OUTPUT_FORMAT="json"; shift ;;
    *) shift ;;
  esac
done

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR -- \
  'resources/*/skills/*/SKILL.md' \
  'resources/*/skills/*/references/*.md' \
  'resources/*/agents/*.md' \
  'resources/*/commands/*.md' \
  'resources/*/commands/*/*.md' \
  'resources/*/scripts/osx-orchestrate' \
  'resources/*/scripts/lib/osx')

declare -a FILE_PATHS=()
declare -a RESOURCE_TYPES=()
declare -a RESOURCE_NAMES=()
declare -a FILE_PLATFORMS=()
declare -a FILE_CURRENT=()
declare -a FILE_PREVIOUS=()
declare -a FILE_STATUS=()
declare -a FILE_ERRORS=()

HAS_ERROR=0

declare -A MANIFEST_CACHE=()

get_or_load_manifest() {
  local platform="$1"
  local which="$2"
  
  local cache_key="$platform:$which"
  if [[ -n "${MANIFEST_CACHE[$cache_key]:-}" ]]; then
    echo "${MANIFEST_CACHE[$cache_key]}"
    return
  fi
  
  local manifest_file manifest_path
  case "$platform" in
    opencode) manifest_file="$PROJECT_ROOT/resources/opencode/manifest.json"; manifest_path="resources/opencode/manifest.json" ;;
    claude)   manifest_file="$PROJECT_ROOT/resources/claude/manifest.json"; manifest_path="resources/claude/manifest.json" ;;
    *) return ;;
  esac
  
  if [[ "$which" == "current" ]]; then
    MANIFEST_CACHE[$cache_key]=$(cat "$manifest_file" 2>/dev/null || echo "{}")
  else
    if git show "HEAD:$manifest_path" &>/dev/null; then
      MANIFEST_CACHE[$cache_key]=$(git show "HEAD:$manifest_path")
    else
      MANIFEST_CACHE[$cache_key]="{}"
    fi
  fi
  
  echo "${MANIFEST_CACHE[$cache_key]}"
}

for file in $STAGED_FILES; do
  resource_info=$(get_resource_info_from_path "$file")
  
  if [[ -z "$resource_info" ]]; then
    continue
  fi
  
  platform=$(get_platform_for_path "$file")
  if [[ -z "$platform" ]]; then
    continue
  fi
  
  IFS=':' read -r resource_type resource_name <<< "$resource_info"
  
  CURRENT_MANIFEST=$(get_or_load_manifest "$platform" "current")
  current_version=$(get_resource_version "$CURRENT_MANIFEST" "$resource_type" "$resource_name")
  
  if [[ -z "$current_version" ]]; then
    FILE_PATHS+=("$file")
    RESOURCE_TYPES+=("$resource_type")
    RESOURCE_NAMES+=("$resource_name")
    FILE_PLATFORMS+=("$platform")
    FILE_CURRENT+=("")
    FILE_PREVIOUS+=("")
    FILE_STATUS+=("error")
    FILE_ERRORS+=("Resource '$resource_name' not found in $platform manifest")
    HAS_ERROR=1
    continue
  fi
  
  if ! validate_semver "$current_version" 2>/dev/null; then
    FILE_PATHS+=("$file")
    RESOURCE_TYPES+=("$resource_type")
    RESOURCE_NAMES+=("$resource_name")
    FILE_PLATFORMS+=("$platform")
    FILE_CURRENT+=("$current_version")
    FILE_PREVIOUS+=("")
    FILE_STATUS+=("error")
    FILE_ERRORS+=("Invalid version format")
    HAS_ERROR=1
    continue
  fi
  
  PREVIOUS_MANIFEST=$(get_or_load_manifest "$platform" "previous")
  previous_version=$(get_resource_version "$PREVIOUS_MANIFEST" "$resource_type" "$resource_name")
  
  if [[ -n "$previous_version" && "$current_version" == "$previous_version" ]]; then
    FILE_PATHS+=("$file")
    RESOURCE_TYPES+=("$resource_type")
    RESOURCE_NAMES+=("$resource_name")
    FILE_PLATFORMS+=("$platform")
    FILE_CURRENT+=("$current_version")
    FILE_PREVIOUS+=("$previous_version")
    FILE_STATUS+=("needs_bump")
    FILE_ERRORS+=("")
    HAS_ERROR=1
  else
    FILE_PATHS+=("$file")
    RESOURCE_TYPES+=("$resource_type")
    RESOURCE_NAMES+=("$resource_name")
    FILE_PLATFORMS+=("$platform")
    FILE_CURRENT+=("$current_version")
    FILE_PREVIOUS+=("${previous_version:-}")
    FILE_STATUS+=("ok")
    FILE_ERRORS+=("")
  fi
done

SCRIPT_FILES=$(git diff --cached --name-only --diff-filter=ACMR -- 'install.sh' 'bin/openspecx')

for file in $SCRIPT_FILES; do
  current_version=$(get_script_version_from_file "$PROJECT_ROOT/$file")
  
  if [[ -z "$current_version" ]]; then
    FILE_PATHS+=("$file")
    RESOURCE_TYPES+=("scripts")
    RESOURCE_NAMES+=("$(basename "$file")")
    FILE_PLATFORMS+=("root")
    FILE_CURRENT+=("")
    FILE_PREVIOUS+=("")
    FILE_STATUS+=("error")
    FILE_ERRORS+=("SCRIPT_VERSION not found in $file")
    HAS_ERROR=1
    continue
  fi
  
  if ! validate_semver "$current_version" 2>/dev/null; then
    FILE_PATHS+=("$file")
    RESOURCE_TYPES+=("scripts")
    RESOURCE_NAMES+=("$(basename "$file")")
    FILE_PLATFORMS+=("root")
    FILE_CURRENT+=("$current_version")
    FILE_PREVIOUS+=("")
    FILE_STATUS+=("error")
    FILE_ERRORS+=("Invalid version format")
    HAS_ERROR=1
    continue
  fi
  
  previous_version=$(get_script_version_from_git "$file")
  file_existed_in_git=$(git show "HEAD:$file" &>/dev/null && echo "true" || echo "false")
  
  if [[ "$file_existed_in_git" == "true" && ( -z "$previous_version" || "$current_version" == "$previous_version" ) ]]; then
    FILE_PATHS+=("$file")
    RESOURCE_TYPES+=("scripts")
    RESOURCE_NAMES+=("$(basename "$file")")
    FILE_PLATFORMS+=("root")
    FILE_CURRENT+=("$current_version")
    FILE_PREVIOUS+=("${previous_version:-}")
    FILE_STATUS+=("needs_bump")
    FILE_ERRORS+=("")
    HAS_ERROR=1
  else
    FILE_PATHS+=("$file")
    RESOURCE_TYPES+=("scripts")
    RESOURCE_NAMES+=("$(basename "$file")")
    FILE_PLATFORMS+=("root")
    FILE_CURRENT+=("$current_version")
    FILE_PREVIOUS+=("${previous_version:-}")
    FILE_STATUS+=("ok")
    FILE_ERRORS+=("")
  fi
done

LOW_CONFIDENCE_INDICES=""

for i in "${!FILE_PATHS[@]}"; do
  if [[ "${FILE_STATUS[$i]}" == "needs_bump" ]]; then
    detect_script="$SCRIPT_DIR/lib/detect-bump"
    if [[ "${FILE_PLATFORMS[$i]}" == "root" ]]; then
      detect_script="$SCRIPT_DIR/lib/detect-bump-script.sh"
    fi
    
    DETECT_RESULT=$("$detect_script" "${FILE_PATHS[$i]}" 2>/dev/null || echo "patch:ambiguous:low")
    
    BUMP_TYPE=$(echo "$DETECT_RESULT" | cut -d: -f1)
    CONFIDENCE=$(echo "$DETECT_RESULT" | cut -d: -f3)
    
    if [[ "$BUMP_TYPE" =~ ^(patch|minor|major)$ ]]; then
      FILE_STATUS[i]="needs_$BUMP_TYPE"
    else
      FILE_STATUS[i]="needs_patch"
      CONFIDENCE="low"
    fi
    
    if [[ "$CONFIDENCE" == "low" ]]; then
      LOW_CONFIDENCE_INDICES="$LOW_CONFIDENCE_INDICES $i"
    fi
  elif [[ "${FILE_STATUS[$i]}" == "new" ]]; then
    FILE_STATUS[i]="needs_minor"
  fi
done

if [[ -n "$LOW_CONFIDENCE_INDICES" ]] && command -v opencode &>/dev/null; then
  AI_FILES_JSON="["
  first=true
  for i in $LOW_CONFIDENCE_INDICES; do
    if [[ "$first" == "true" ]]; then
      first=false
    else
      AI_FILES_JSON+=","
    fi
    AI_FILES_JSON+="{\"path\":\"${FILE_PATHS[$i]}\",\"current_version\":\"${FILE_CURRENT[$i]}\"}"
  done
  AI_FILES_JSON+="]"
  
  ANALYSIS_TIMEOUT=60
  ANALYSIS_FILE=$(mktemp)
  
  timeout "$ANALYSIS_TIMEOUT" opencode run --format json \
    "Analyze these ambiguous file changes. Return JSON array with objects containing 'path' and 'status' (needs_patch, needs_minor, or needs_major). Input: $AI_FILES_JSON. Output ONLY a JSON array, no markdown, no explanation." \
    >"$ANALYSIS_FILE" 2>/dev/null
  
  if [[ -s "$ANALYSIS_FILE" ]]; then
    TEXT_OUTPUT=$(grep '"type":"text"' "$ANALYSIS_FILE" | head -1 | jq -r '.part.text // empty' 2>/dev/null || echo "")
    
    if [[ -n "$TEXT_OUTPUT" ]] && echo "$TEXT_OUTPUT" | jq -e 'type == "array"' >/dev/null 2>&1; then
      for i in $LOW_CONFIDENCE_INDICES; do
        AI_STATUS=$(echo "$TEXT_OUTPUT" | jq -r --arg path "${FILE_PATHS[$i]}" '.[] | select(.path == $path) | .status // empty' 2>/dev/null || echo "")
        if [[ -n "$AI_STATUS" && "$AI_STATUS" =~ ^needs_(patch|minor|major)$ ]]; then
          FILE_STATUS[i]="$AI_STATUS"
        fi
      done
    fi
  fi
  
  rm -f "$ANALYSIS_FILE"
fi

build_files_json() {
  local files_json="["
  local first=true
  
  for i in "${!FILE_PATHS[@]}"; do
    if [[ "$first" == "true" ]]; then
      first=false
    else
      files_json+=","
    fi
    
    files_json+="{\"path\":\"${FILE_PATHS[$i]}\",\"platform\":\"${FILE_PLATFORMS[$i]}\",\"resource_type\":\"${RESOURCE_TYPES[$i]}\",\"resource_name\":\"${RESOURCE_NAMES[$i]}\",\"current_version\":\"${FILE_CURRENT[$i]}\",\"status\":\"${FILE_STATUS[$i]}\"}"
  done
  
  files_json+="]"
  echo "$files_json"
}

output_json() {
  local status="ok"
  if [[ $HAS_ERROR -eq 1 ]]; then
    status="error"
  fi
  
  local files_json
  files_json=$(build_files_json)
  
  write_version_state "$status" "$files_json"
  
  echo "{\"status\":\"$status\",\"files\":$files_json}"
}

output_table() {
  local status="ok"
  if [[ $HAS_ERROR -eq 1 ]]; then
    status="error"
  fi
  
  local files_json
  files_json=$(build_files_json)
  
  write_version_state "$status" "$files_json"
  
  if [[ $HAS_ERROR -eq 0 ]]; then
    return
  fi
  
  echo ""
  echo "Version Bump Required"
  echo "====================="
  echo ""
  
  printf "%-50s  %-20s  %-10s  %-15s\n" "File" "Resource" "Current" "Status"
  printf "%-50s  %-20s  %-10s  %-15s\n" "$(printf '=%.0s' {1..50})" "$(printf '=%.0s' {1..20})" "$(printf '=%.0s' {1..10})" "$(printf '=%.0s' {1..15})"
  
  for i in "${!FILE_PATHS[@]}"; do
    local display_path="${FILE_PATHS[$i]}"
    if [[ ${#display_path} -gt 48 ]]; then
      display_path="...${display_path: -45}"
    fi
    
    local status_text="${FILE_STATUS[$i]}"
    local resource_display="${RESOURCE_NAMES[$i]}"
    
    printf "%-50s  %-20s  %-10s  %-15s\n" "$display_path" "$resource_display" "${FILE_CURRENT[$i]}" "$status_text"
  done
  
  echo ""
  echo "Run: mise run version:update"
}

if [[ "$OUTPUT_FORMAT" == "json" ]]; then
  output_json
else
  output_table
fi

if [[ $HAS_ERROR -eq 1 ]]; then
  exit 1
fi

exit 0
