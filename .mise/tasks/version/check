#!/usr/bin/env python3
"""Verify version bump when versioned files are modified."""

from __future__ import annotations

import json
import subprocess
import sys
from pathlib import Path
from typing import Optional

sys.path.insert(0, str(Path(__file__).parent / "lib"))

from manifest import (
    Manifest,
    get_platform_for_path,
    get_resource_info_from_path,
    validate_semver,
)
from detect import detect_bump_for_resource
from state import write_version_state


def get_staged_files() -> list[str]:
    patterns = [
        "resources/*/skills/*/SKILL.md",
        "resources/*/skills/*/references/*.md",
        "resources/*/skills/*/scripts/*",
        "resources/*/agents/*.md",
        "resources/*/commands/*.md",
        "resources/*/commands/*/*.md",
        "resources/*/scripts/osx-orchestrate",
        "resources/*/scripts/lib/osx",
    ]

    try:
        result = subprocess.run(
            ["git", "diff", "--cached", "--name-only", "--diff-filter=ACMR", "--"] + patterns,
            capture_output=True,
            text=True,
            check=True,
        )
        return [f for f in result.stdout.strip().split("\n") if f]
    except subprocess.CalledProcessError:
        return []


def get_script_files() -> list[str]:
    try:
        result = subprocess.run(
            ["git", "diff", "--cached", "--name-only", "--diff-filter=ACMR", "--", "install.sh", "bin/openspecx"],
            capture_output=True,
            text=True,
            check=True,
        )
        return [f for f in result.stdout.strip().split("\n") if f]
    except subprocess.CalledProcessError:
        return []


def get_git_show_content(path: str) -> Optional[str]:
    try:
        result = subprocess.run(
            ["git", "show", f"HEAD:{path}"],
            capture_output=True,
            text=True,
        )
        if result.returncode == 0:
            return result.stdout
    except subprocess.CalledProcessError:
        pass
    return None


def get_script_version_from_file(file_path: str) -> Optional[str]:
    path = Path(file_path)
    if not path.exists():
        return None
    for line in path.read_text().split("\n"):
        if line.startswith("SCRIPT_VERSION="):
            return line.split("=", 1)[1].strip().strip('"')
    return None


def main():
    output_format = "table"
    if len(sys.argv) > 1 and sys.argv[1] == "--json":
        output_format = "json"

    staged_files = get_staged_files()
    script_files = get_script_files()

    files = []

    for file_path in staged_files:
        resource_info = get_resource_info_from_path(file_path)
        if not resource_info:
            continue

        platform = get_platform_for_path(file_path)
        if not platform:
            continue

        resource_type, resource_name = resource_info.split(":", 1)

        try:
            manifest = Manifest.load(platform)
        except Exception:
            files.append({
                "path": file_path,
                "platform": platform,
                "resource_type": resource_type,
                "resource_name": resource_name,
                "current_version": "",
                "status": "error",
                "error": f"Could not load {platform} manifest",
            })
            continue

        current_version = manifest.get_resource_version(resource_type, resource_name)

        if not current_version:
            files.append({
                "path": file_path,
                "platform": platform,
                "resource_type": resource_type,
                "resource_name": resource_name,
                "current_version": "",
                "status": "error",
                "error": f"Resource '{resource_name}' not found in {platform} manifest",
            })
            continue

        if not validate_semver(current_version):
            files.append({
                "path": file_path,
                "platform": platform,
                "resource_type": resource_type,
                "resource_name": resource_name,
                "current_version": current_version,
                "status": "error",
                "error": "Invalid version format",
            })
            continue

        git_content = get_git_show_content(file_path)
        if git_content:
            files.append({
                "path": file_path,
                "platform": platform,
                "resource_type": resource_type,
                "resource_name": resource_name,
                "current_version": current_version,
                "status": "needs_bump",
                "error": "",
            })
        else:
            files.append({
                "path": file_path,
                "platform": platform,
                "resource_type": resource_type,
                "resource_name": resource_name,
                "current_version": current_version,
                "status": "ok",
                "error": "",
            })

    for file_path in script_files:
        current_version = get_script_version_from_file(file_path)

        if not current_version:
            files.append({
                "path": file_path,
                "platform": "root",
                "resource_type": "scripts",
                "resource_name": Path(file_path).name,
                "current_version": "",
                "status": "error",
                "error": "SCRIPT_VERSION not found",
            })
            continue

        if not validate_semver(current_version):
            files.append({
                "path": file_path,
                "platform": "root",
                "resource_type": "scripts",
                "resource_name": Path(file_path).name,
                "current_version": current_version,
                "status": "error",
                "error": "Invalid version format",
            })
            continue

        git_content = get_git_show_content(file_path)
        if git_content:
            files.append({
                "path": file_path,
                "platform": "root",
                "resource_type": "scripts",
                "resource_name": Path(file_path).name,
                "current_version": current_version,
                "status": "needs_bump",
                "error": "",
            })
        else:
            files.append({
                "path": file_path,
                "platform": "root",
                "resource_type": "scripts",
                "resource_name": Path(file_path).name,
                "current_version": current_version,
                "status": "ok",
                "error": "",
            })

    for f in files:
        if f["status"] == "needs_bump":
            if f["platform"] == "root":
                result = detect_bump_for_resource(f["path"])
            else:
                result = detect_bump_for_resource(f["path"])

            if result.bump_type in ("patch", "minor", "major"):
                f["status"] = f"needs_{result.bump_type}"
            else:
                f["status"] = "needs_patch"

    has_error = any(1 for f in files if f["status"].startswith("error") or f["status"].startswith("needs_"))
    status = "error" if has_error else "ok"

    files_json = json.dumps(files)

    if output_format == "json":
        write_version_state(status, files_json)
        print(json.dumps({"status": status, "files": files}))
    else:
        write_version_state(status, files_json)

        if not has_error:
            return

        print("")
        print("Version Bump Required")
        print("=====================")
        print("")

        header = f"{'File':<50}  {'Resource':<20}  {'Current':<10}  {'Status':<15}"
        print(header)
        print("=" * len(header))

        for f in files:
            display_path = f["path"]
            if len(display_path) > 48:
                display_path = "..." + display_path[-45:]

            print(f"{display_path:<50}  {f['resource_name']:<20}  {f['current_version']:<10}  {f['status']:<15}")

        print("")
        print("Run: mise run version:update")

    if has_error:
        sys.exit(1)


if __name__ == "__main__":
    main()
