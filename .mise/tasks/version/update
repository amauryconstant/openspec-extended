#!/usr/bin/env bash
#MISE description="Bump version in all paired files for a concept"
#USAGE arg "<concept>" help="Concept name (concepts, changelog, maintain-docs, modify, review, verify-tests, auto)"
#USAGE arg "<bump>" help="Version bump type" {
#USAGE   choices "patch" "minor" "major"
#USAGE }

set -euo pipefail

CONCEPT="${usage_concept?}"
BUMP_TYPE="${usage_bump?}"

declare -A CONCEPT_CONFIG=(
  ["concepts"]="openspec-concepts:skill"
  ["changelog"]="openspec-generate-changelog:skill"
  ["maintain-docs"]="openspec-maintain-ai-docs:skill"
  ["modify"]="openspec-modify-artifacts:skill"
  ["review"]="openspec-review-artifacts:skill"
  ["verify-tests"]="openspec-review-test-compliance:skill"
  ["auto"]="auto:script"
)

if [[ -z "${CONCEPT_CONFIG[$CONCEPT]:-}" ]]; then
  echo "Error: Unknown concept: $CONCEPT"
  echo "Valid concepts: ${!CONCEPT_CONFIG[*]}"
  exit 1
fi

IFS=':' read -r SKILL_DIR FILE_TYPE <<< "${CONCEPT_CONFIG[$CONCEPT]}"

get_version_yaml() {
  local file="$1"
  grep -A2 "^metadata:" "$file" 2>/dev/null | grep "version:" | head -1 | sed 's/.*version: *["'\'']*\([^"'\'']*\)["'\'']*.*/\1/' || echo ""
}

set_version_yaml() {
  local file="$1"
  local version="$2"
  sed -i "s/^\(  version: *\)\".*\"/\1\"$version\"/" "$file"
}

get_version_bash() {
  local file="$1"
  grep "^readonly SCRIPT_VERSION=" "$file" 2>/dev/null | sed 's/SCRIPT_VERSION="\([^"]*\)"/\1/' || echo ""
}

set_version_bash() {
  local file="$1"
  local version="$2"
  sed -i "s/^readonly SCRIPT_VERSION=\".*\"/readonly SCRIPT_VERSION=\"$version\"/" "$file"
}

declare -a FILES=()

if [[ "$FILE_TYPE" == "skill" ]]; then
  FILES=(
    "resources/claude/skills/${SKILL_DIR}/SKILL.md"
    "resources/opencode/skills/${SKILL_DIR}/SKILL.md"
    "resources/claude/commands/opsx/${CONCEPT}.md"
    "resources/opencode/commands/opsx-${CONCEPT}.md"
  )
elif [[ "$FILE_TYPE" == "script" ]]; then
  FILES=(
    "resources/claude/scripts/openspec-auto"
    "resources/opencode/scripts/openspec-auto"
    "resources/claude/agents/openspec-analyzer.md"
    "resources/claude/agents/openspec-builder.md"
    "resources/claude/agents/openspec-maintainer.md"
    "resources/opencode/agents/openspec-analyzer.md"
    "resources/opencode/agents/openspec-builder.md"
    "resources/opencode/agents/openspec-maintainer.md"
  )
fi

FIRST_FILE="${FILES[0]}"
if [[ ! -f "$FIRST_FILE" ]]; then
  echo "Error: File not found: $FIRST_FILE"
  exit 1
fi

if [[ "$FIRST_FILE" == *.md ]]; then
  CURRENT_VERSION=$(get_version_yaml "$FIRST_FILE")
else
  CURRENT_VERSION=$(get_version_bash "$FIRST_FILE")
fi

if [[ -z "$CURRENT_VERSION" ]]; then
  echo "Error: No version found in $FIRST_FILE"
  exit 1
fi

IFS='.' read -r MAJOR MINOR PATCH <<< "$CURRENT_VERSION"

case "$BUMP_TYPE" in
  patch)
    NEW_PATCH=$((PATCH + 1))
    NEW_VERSION="${MAJOR}.${MINOR}.${NEW_PATCH}"
    ;;
  minor)
    NEW_MINOR=$((MINOR + 1))
    NEW_VERSION="${MAJOR}.${NEW_MINOR}.0"
    ;;
  major)
    NEW_MAJOR=$((MAJOR + 1))
    NEW_VERSION="${NEW_MAJOR}.0.0"
    ;;
esac

echo "Bumping: $CURRENT_VERSION → $NEW_VERSION"
echo ""

UPDATED=0
for file in "${FILES[@]}"; do
  if [[ -f "$file" ]]; then
    if [[ "$file" == *.md ]]; then
      set_version_yaml "$file" "$NEW_VERSION"
    else
      set_version_bash "$file" "$NEW_VERSION"
    fi
    echo "✓ $file"
    ((UPDATED++))
  else
    echo "⊘ $file (not found)"
  fi
done

echo ""
echo "Updated $UPDATED files to $NEW_VERSION"
