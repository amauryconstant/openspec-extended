#!/usr/bin/env python3
"""Bump version in manifest for resources needing updates."""

from __future__ import annotations

import json
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).parent / "lib"))

from manifest import (
    Manifest,
    bump_semver,
    highest_bump_type,
    validate_semver,
)
from state import get_state_files, get_state_status


def get_manifest_file_for_platform(platform: str) -> str:
    return str(Path(__file__).resolve().parents[3] / "resources" / platform / "manifest.toml")


def bump_resource_version(platform: str, resource_type: str, resource_name: str, bump_type: str, dry_run: bool = False) -> bool:
    manifest_path = get_manifest_file_for_platform(platform)
    manifest_file = Path(manifest_path)

    if not manifest_file.exists():
        print(f"Error: Manifest not found for platform '{platform}'", file=sys.stderr)
        return False

    try:
        manifest = Manifest.load(platform)
    except Exception as e:
        print(f"Error: Could not load manifest: {e}", file=sys.stderr)
        return False

    current_version = manifest.get_resource_version(resource_type, resource_name)

    if not current_version:
        print(f"Error: Resource '{resource_name}' not found in {platform} manifest", file=sys.stderr)
        return False

    if not validate_semver(current_version):
        return False

    new_version = bump_semver(current_version, bump_type)

    print(f"  [{platform}] {resource_name}: {current_version} → {new_version}")

    if dry_run:
        print(f"    ✓ {resource_type}/{resource_name} (dry-run)")
        return True

    manifest.set_resource_version(resource_type, resource_name, new_version)
    manifest.save()
    print(f"    ✓ {resource_type}/{resource_name}")
    return True


def get_script_file_for_name(script_name: str) -> Path:
    project_root = Path(__file__).resolve().parents[3]
    if script_name == "install.sh":
        return project_root / "install.sh"
    elif script_name == "openspecx":
        return project_root / "bin" / "openspecx"
    return None


def get_script_version_from_file(file_path: Path) -> str:
    for line in file_path.read_text().split("\n"):
        if line.startswith("SCRIPT_VERSION="):
            return line.split("=", 1)[1].strip().strip('"')
    return ""


def bump_script_version_in_file(file_path: Path, new_version: str) -> None:
    content = file_path.read_text()
    lines = []
    for line in content.split("\n"):
        if line.startswith("SCRIPT_VERSION="):
            lines.append(f'SCRIPT_VERSION="{new_version}"')
        else:
            lines.append(line)
    file_path.write_text("\n".join(lines) + "\n")


def main():
    dry_run = "--dry-run" in sys.argv

    state_status = get_state_status()
    if state_status != "error":
        print(f"No version bumps required (status: {state_status})")
        sys.exit(0)

    state_files_json = get_state_files()
    if state_files_json == "[]":
        print("No files in state. Run 'mise run version:check' first.")
        sys.exit(1)

    try:
        state_files = json.loads(state_files_json)
    except json.JSONDecodeError:
        print("Invalid state file. Run 'mise run version:check' first.")
        sys.exit(1)

    resource_bumps = {}
    script_bumps = {}

    for f in state_files:
        platform = f.get("platform", "")
        resource_type = f.get("resource_type", "")
        resource_name = f.get("resource_name", "")
        status = f.get("status", "")

        if not platform or not resource_type or not resource_name:
            continue

        if not status.startswith("needs_"):
            continue

        bump_type = status.replace("needs_", "")

        if platform == "root" and resource_type == "scripts":
            script_bumps[resource_name] = bump_type
        else:
            resource_key = f"{platform}:{resource_type}:{resource_name}"
            existing = resource_bumps.get(resource_key)
            if existing:
                resource_bumps[resource_key] = highest_bump_type(existing, bump_type)
            else:
                resource_bumps[resource_key] = bump_type

    if not resource_bumps and not script_bumps:
        print("No version bumps required")
        sys.exit(0)

    if resource_bumps:
        print("Executing version bumps in manifests:")
        print("")

        for resource_key, bump_type in resource_bumps.items():
            platform, resource_type, resource_name = resource_key.split(":", 2)
            bump_resource_version(platform, resource_type, resource_name, bump_type, dry_run)

        print("")

    if script_bumps:
        print("Executing version bumps in scripts:")
        print("")

        for script_name, bump_type in script_bumps.items():
            script_file = get_script_file_for_name(script_name)

            if not script_file or not script_file.exists():
                print(f"  Warning: Script not found: {script_name}", file=sys.stderr)
                continue

            current_version = get_script_version_from_file(script_file)

            if not current_version:
                print(f"  Error: SCRIPT_VERSION not found in {script_file.name}", file=sys.stderr)
                continue

            new_version = bump_semver(current_version, bump_type)

            print(f"  [root] {script_name}: {current_version} → {new_version}")

            if dry_run:
                print(f"    ✓ scripts/{script_name} (dry-run)")
            else:
                bump_script_version_in_file(script_file, new_version)
                print(f"    ✓ scripts/{script_name}")

        print("")

    print("Done. Commit the changes.")


if __name__ == "__main__":
    main()
