#!/usr/bin/env bash
#MISE description="Bump version in manifest for resources needing updates"
#USAGE flag "--dry-run" help="Show what would be updated without making changes"

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=/dev/null
source "$SCRIPT_DIR/lib/common.sh"

DRY_RUN=false

while [[ $# -gt 0 ]]; do
  case "$1" in
    --dry-run) DRY_RUN=true; shift ;;
    *) shift ;;
  esac
done

get_manifest_file_for_platform() {
  local platform="$1"
  case "$platform" in
    opencode) echo "$PROJECT_ROOT/resources/opencode/manifest.json" ;;
    claude)   echo "$PROJECT_ROOT/resources/claude/manifest.json" ;;
    *) echo "" ;;
  esac
}

bump_resource_version() {
  local platform="$1"
  local resource_type="$2"
  local resource_name="$3"
  local bump_type="$4"
  
  local manifest_file
  manifest_file=$(get_manifest_file_for_platform "$platform")
  
  if [[ -z "$manifest_file" || ! -f "$manifest_file" ]]; then
    echo "Error: Manifest not found for platform '$platform'" >&2
    return 1
  fi
  
  local current_version
  current_version=$(get_resource_version "$(cat "$manifest_file")" "$resource_type" "$resource_name")
  
  if [[ -z "$current_version" ]]; then
    echo "Error: Resource '$resource_name' not found in $platform manifest" >&2
    return 1
  fi
  
  if ! validate_semver "$current_version"; then
    return 1
  fi
  
  local new_version
  new_version=$(bump_version "$current_version" "$bump_type")
  
  echo "  [$platform] $resource_name: $current_version → $new_version"
  
  if [[ "$DRY_RUN" == "true" ]]; then
    echo "    ✓ $resource_type/$resource_name (dry-run)"
    return 0
  fi
  
  set_resource_version "$manifest_file" "$resource_type" "$resource_name" "$new_version"
  echo "    ✓ $resource_type/$resource_name"
  
  return 0
}

if [[ ! -f "$VERSION_STATE_FILE" ]]; then
  echo "Error: No state file found. Run 'mise run version:check' first." >&2
  exit 1
fi

STATE_STATUS=$(get_state_status)
if [[ "$STATE_STATUS" != "error" ]]; then
  echo "No version bumps required (status: $STATE_STATUS)"
  exit 0
fi

STATE_FILES=$(get_state_files)
if [[ "$STATE_FILES" == "[]" ]]; then
  echo "No files in state. Run 'mise run version:check' first."
  exit 1
fi

declare -A RESOURCE_BUMPS=()

while IFS= read -r file_entry; do
  [[ -z "$file_entry" ]] && continue
  
  platform=$(echo "$file_entry" | jq -r '.platform // empty')
  resource_type=$(echo "$file_entry" | jq -r '.resource_type // empty')
  resource_name=$(echo "$file_entry" | jq -r '.resource_name // empty')
  status=$(echo "$file_entry" | jq -r '.status // empty')
  
  if [[ -z "$platform" || -z "$resource_type" || -z "$resource_name" ]]; then
    continue
  fi
  
  if [[ "$platform" == "root" && "$resource_type" == "scripts" ]]; then
    continue
  fi
  
  if [[ ! "$status" =~ ^needs_(patch|minor|major)$ ]]; then
    continue
  fi
  
  bump_type=$(echo "$status" | sed 's/needs_//')
  
  resource_key="$platform:$resource_type:$resource_name"
  existing="${RESOURCE_BUMPS[$resource_key]:-}"
  
  if [[ -z "$existing" ]]; then
    RESOURCE_BUMPS[$resource_key]="$bump_type"
  else
    RESOURCE_BUMPS[$resource_key]=$(highest_bump_type "$existing $bump_type")
  fi
done < <(echo "$STATE_FILES" | jq -c '.[]')

declare -A SCRIPT_BUMPS=()

while IFS= read -r file_entry; do
  [[ -z "$file_entry" ]] && continue
  
  platform=$(echo "$file_entry" | jq -r '.platform // empty')
  resource_type=$(echo "$file_entry" | jq -r '.resource_type // empty')
  resource_name=$(echo "$file_entry" | jq -r '.resource_name // empty')
  status=$(echo "$file_entry" | jq -r '.status // empty')
  
  if [[ "$platform" != "root" || "$resource_type" != "scripts" ]]; then
    continue
  fi
  
  if [[ ! "$status" =~ ^needs_(patch|minor|major)$ ]]; then
    continue
  fi
  
  bump_type=$(echo "$status" | sed 's/needs_//')
  SCRIPT_BUMPS[$resource_name]="$bump_type"
done < <(echo "$STATE_FILES" | jq -c '.[]')

if [[ ${#RESOURCE_BUMPS[@]} -eq 0 && ${#SCRIPT_BUMPS[@]} -eq 0 ]]; then
  echo "No version bumps required"
  exit 0
fi

if [[ ${#RESOURCE_BUMPS[@]} -gt 0 ]]; then
  echo "Executing version bumps in manifests:"
  echo ""

  for resource_key in "${!RESOURCE_BUMPS[@]}"; do
    IFS=':' read -r platform resource_type resource_name <<< "$resource_key"
    bump_type="${RESOURCE_BUMPS[$resource_key]}"
    bump_resource_version "$platform" "$resource_type" "$resource_name" "$bump_type"
  done
  
  echo ""
fi

if [[ ${#SCRIPT_BUMPS[@]} -gt 0 ]]; then
  echo "Executing version bumps in scripts:"
  echo ""
  
  for script_name in "${!SCRIPT_BUMPS[@]}"; do
    bump_type="${SCRIPT_BUMPS[$script_name]}"
    
    script_file=""
    case "$script_name" in
      install.sh)  script_file="$PROJECT_ROOT/install.sh" ;;
      openspecx)   script_file="$PROJECT_ROOT/bin/openspecx" ;;
      *) continue ;;
    esac
    
    if [[ ! -f "$script_file" ]]; then
      echo "  Warning: Script not found: $script_file" >&2
      continue
    fi
    
    current_version=$(get_script_version_from_file "$script_file")
    
    if [[ -z "$current_version" ]]; then
      echo "  Error: SCRIPT_VERSION not found in $script_file" >&2
      continue
    fi
    
    new_version=$(bump_version "$current_version" "$bump_type")
    
    echo "  [root] $script_name: $current_version → $new_version"
    
    if [[ "$DRY_RUN" == "true" ]]; then
      echo "    ✓ scripts/$script_name (dry-run)"
    else
      bump_script_version_in_file "$script_file" "$new_version"
      echo "    ✓ scripts/$script_name"
    fi
  done
  
  echo ""
fi

echo "Done. Commit the changes."
